#!/usr/bin/env bash
# brain-handoff-run-start — canonical wrapper for handoff_run_start.sh
HDIR="${BRAIN_DIR:-$HOME/gmgn-brain}/scripts/lib/handoff-system"
if [[ "handoff_run_start.sh" == *.py ]]; then
  exec python3 "$HDIR/handoff_run_start.sh" "$@"
else
  exec bash "$HDIR/handoff_run_start.sh" "$@"
fi
