    f = len(d.get('findings', []))
    t = d.get('verified_at', '')[:10]
    print(f'{v} ({c}) | {f} finding(s) | {t}')
except Exception:
    pass
" "$_branch_verdict" 2>/dev/null) || true
  else
    CODEX_VERIFY_LINE="not yet verified -- run: brain-review-dispatch ${_pending_auto_head} --type verification"
  fi
elif [[ -d "$_codex_dir" ]]; then
  # No auto branch -- show newest verdict globally
  _newest_verdict=$(ls -t "$_codex_dir"/*.json 2>/dev/null | head -1)
  if [[ -n "$_newest_verdict" ]]; then
    CODEX_VERIFY_LINE=$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    v = d.get('verdict', '?')
    c = d.get('commit', '?')[:7]
    f = len(d.get('findings', []))
    t = d.get('verified_at', '')[:10]
    print(f'{v} ({c}) | {f} finding(s) | {t}')
except Exception:
    pass
" "$_newest_verdict" 2>/dev/null) || true
  fi
fi

# ── Compute velocity summary from build-metrics ─────────────────
VELOCITY_LINE=""
_metrics_file="$BRAIN/work/logs/build-metrics.jsonl"
if [[ -f "$_metrics_file" ]]; then
  VELOCITY_LINE=$(python3 -c "
import json, sys
sessions = []
tasks_total = 0
cost_total = 0.0
hours_total = 0.0
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            d = json.loads(line)
        except:
            continue
        if d.get('type') == 'session_end':
            sessions.append(d)
            tasks_total += d.get('tasks_completed', 0)
            cost_total += d.get('session_cost_usd', 0) or 0
            hours_total += (d.get('duration_minutes', 0) or 0) / 60.0
        elif d.get('type') == 'task_complete':
            if not any(s.get('tasks_completed', 0) > 0 for s in sessions):
                tasks_total += 1
n = len(sessions)
if n == 0 or hours_total < 0.1:
    sys.exit(0)
rate = tasks_total / hours_total if hours_total > 0 else 0
cpt = cost_total / tasks_total if tasks_total > 0 else 0
parts = [f'{tasks_total} tasks in {n} sessions']
if rate >= 0.1:
    parts.append(f'{rate:.1f}/hr')
if cost_total > 0 and tasks_total > 0:
    parts.append(f'\${cpt:.0f}/task')
print(' | '.join(parts))
" "$_metrics_file" 2>/dev/null || echo "")
fi

