import re
import sys
from pathlib import Path

manual_path = Path(sys.argv[1])
digest_path = Path(sys.argv[2])
generated_at = sys.argv[3]
out_path = Path(sys.argv[4])

manual = manual_path.read_text()
digest = digest_path.read_text()

def section(text: str, heading: str, next_heading: str) -> str:
    pat = re.compile(rf"{re.escape(heading)}\n(.*?)(?=\n{re.escape(next_heading)}\n)", re.DOTALL)
    m = pat.search(text)
    return m.group(1).strip() if m else ""

def strip_blanks(lines):
    return [ln.rstrip() for ln in lines if ln.strip()]

verdict_block = section(manual, "### 2.2 Verdict gate", "### 2.3 Inbox and triage")
auth_block = section(manual, "### 6.2 Session-start gate (all seats)", "### 6.3 Session-close pipeline")
destructive_block = section(manual, "### 9.2 Destructive operations", "### 9.3 Publishing")
permission_block = section(
    manual,
    "### 9.13 Permission modes and authority stops (applies_to: all)",
    "### 9.16 Sub-agent dispatch — custom system over native (applies_to: all)",
)

auth_lines = []
for ln in auth_block.splitlines():
    if "Present a concise briefing to the operator. STOP." in ln:
        auth_lines.append(ln.strip())
    if "Do NOT Read task files, queue files, or any work artifacts before" in ln:
        auth_lines.append(ln.strip())
    if "presenting the briefing and receiving explicit human authorization." in ln:
        auth_lines.append(ln.strip())
    if "Seeing \"N tasks queued\" in the brief is NOT authorization to open them." in ln:
        auth_lines.append(ln.strip())

destructive_lines = []
for ln in destructive_block.splitlines():
    s = ln.rstrip()
    if not s.strip():
        if destructive_lines:
            break
        continue
    destructive_lines.append(s)

permission_lines = []
capture = False
captured_any = False
for ln in permission_block.splitlines():
    s = ln.rstrip()
    if "remove or weaken any of the following:" in s:
        capture = True
        continue
    if capture:
        if not s.strip():
            if captured_any:
                break
            continue
        permission_lines.append(s)
        if s.lstrip().startswith("- "):
            captured_any = True
permission_lines = strip_blanks(permission_lines)

digest_samples = []
for sec in (
    "Memory Digest: Core Rules",
    "Memory Digest: Session Lifecycle",
    "Memory Digest: Tools & Capabilities",
    "Memory Digest: Infrastructure Safety",
    "Memory Digest: Content & Publishing",
    "Memory Digest: Governance",
    "Memory Digest: Multi-Seat",
):
    m = re.search(rf"# {re.escape(sec)}\n(.*?)(?=\n# Memory Digest:|\Z)", digest, re.DOTALL)
    if not m:
        continue
    body = m.group(1)
    bullet = ""
    for line in body.splitlines():
        if line.startswith("- "):
            bullet = line
            break
    if bullet:
        digest_samples.append((sec.replace("Memory Digest: ", ""), bullet))

lines = [
    "---",
    'title: "Session-Start Contract (Tier-0, compact)"',
    'type: "auto-generated"',
    f'generated: "{generated_at}"',
    'source: "brain/MANUAL.md + brain/index/digest-preamble.md"',
    'applies_to: "all"',
    "---",
    "",
    "# Session-Start Contract (Tier-0)",
    "",
    "> Mandatory startup contract read for every seat before first authorized action.",
    "> Long-form manuals and digests are on-demand lookup surfaces only.",
    "",
    "## Startup Sequence (All Seats)",
    "",
    "1. Launch canonical operator command (`brain-claude` / `brain-codex` / `brain-gemini`).",
    "2. Use bootstrap summary source (`session-brief.md` for Claude, stdout tail for Codex/Gemini).",
    "3. Read this file (`brain/index/session-start-contract.compact.md`).",
    "4. Check Prepared Focus in the summary.",
    "5. Present briefing and STOP until explicit human authorization.",
    "",
    "## Authorization Stop (Verbatim)",
    "",
]
lines.extend(auth_lines or [
    "**Present a concise briefing to the operator. STOP.**",
    "Do NOT Read task files, queue files, or any work artifacts before presenting the briefing and receiving explicit human authorization.",
    'Seeing "N tasks queued" in the brief is NOT authorization to open them.',
])
lines.extend([
    "",
    "## Verdict Gate (Verbatim)",
    "",
])
lines.extend(strip_blanks(verdict_block.splitlines()))
lines.extend([
    "",
    "## Safety and Approval Boundaries (Verbatim excerpts)",
    "",
])
lines.extend(destructive_lines)
lines.append("")
lines.extend(permission_lines)
lines.extend([
    "",
    "## Seat Overlay (Minimal)",
    "",
    "- Claude Code: read `brain/index/session-brief.md` (SessionStart output file).",
    "- Codex: use `brain-codex` launcher/bootstrap stdout tail as brief source.",
    "- Gemini: use `brain-gemini` launcher/bootstrap stdout tail as brief source.",
    "",
    "## On-Demand Lookup (Not Mandatory at startup)",
    "",
    "- `brain/MANUAL.md` (full contract and lifecycle details).",
    "- `brain/index/digest-preamble.md` (full one-line digest index).",
    "- `brain/index/session-resume.md` (open only on anomaly or explicit operator request).",
    "",
    "## Digest Coverage Snapshot",
    "",
    f"- Sections detected: {len(digest_samples)}",
])
for name, bullet in digest_samples:
    lines.append(f"- {name}: {bullet[2:]}")

out_path.write_text("\n".join(lines) + "\n")
PYTIER0
mv "$_SESSION_CONTRACT_TMP" "$_SESSION_CONTRACT"
echo "[brain-resume] Session-start contract written to $_SESSION_CONTRACT"
fi

# Write session brief to both stdout and session-brief.md (for hook injection into systemMessage)
if ! $CLOSE_REFRESH; then
_SESSION_BRIEF="$BRAIN/brain/index/session-brief.md"
{
echo ""
echo "=== Session Resume ==="
if [[ -n "$VERDICT_STATUS" ]]; then
  if [[ "$VERDICT_STATUS" == "OK" ]]; then
    echo "Brain Verdict: OK"
  else
    echo "Brain Verdict: $VERDICT_STATUS ($VERDICT_ISSUE_COUNT issue(s))"
  fi
fi
[[ -n "$LATEST_HANDOFF" ]] && echo "HANDOFF: $LATEST_HANDOFF"
[[ -n "$LATEST_CHECKPOINT" ]] && echo "CHECKPOINT: $LATEST_CHECKPOINT ($CHECKPOINT_CHANGES changed, $CHECKPOINT_AHEAD ahead)"
[[ $CORRECTIONS_COUNT -gt 0 ]] && echo "CLIP CORRECTIONS: $CORRECTIONS_COUNT new correction(s) from the operator — review and update brain"
[[ $P1_COUNT -gt 0 ]] && echo "P1 BLOCKING: $P1_COUNT item(s) — check priority-queue.md"
[[ $P2_COUNT -gt 0 ]] && echo "P2 IMPORTANT: $P2_COUNT item(s) — check priority-queue.md"
[[ $QUEUED_COUNT -gt 0 ]] && echo "URGENT: $QUEUED_COUNT queued message(s) — run brain-message list"
[[ $FIRED_COUNT -gt 0 ]] && echo "REMINDER: $FIRED_COUNT reminder(s) have fired"
echo "Last commits: $(echo "$COMMITS" | wc -l | tr -d ' ')"
echo "System health: $HEALTH_SUMMARY"
echo "Activity: $(echo "$RECENT_ACTIVITY" | wc -l | tr -d ' ') recent entries"
echo "Review: triage=$REVIEW_TRIAGE_AGE, weekly=$REVIEW_WEEKLY_AGE"
echo "Inbox: $INBOX_COUNT items | Pending deletions: $PENDING_COUNT | Suggestions: $SUGGESTION_COUNT | Open Qs: $OPEN_Q_COUNT"
[[ -n "$SPOTCHECK_SCORE" ]] && echo "Spotcheck: $SPOTCHECK_SCORE | Ingest: $INGEST_COUNT digest(s)"
[[ $ACTIVE_TASK_COUNT -gt 0 ]] && echo "Tasks: $ACTIVE_TASK_COUNT active, $BLOCKED_TASK_COUNT blocked"
echo "Task Queue: $OPS_QUEUED_COUNT queued, $OPS_ACTIVE_COUNT active, $OPS_COMPLETED_COUNT completed"
[[ -n "$LATEST_SNAPSHOT" ]] && echo "Snapshot: $LATEST_SNAPSHOT"
[[ -n "$DRIFT_SCORE" ]] && echo "Clip drift: ${DRIFT_SCORE}% — $DRIFT_VERDICT"
[[ -n "$LATEST_SEEDS" ]] && echo "Seeds: $SEEDS_COUNT digest(s)"
[[ -n "$LATEST_CURATE" ]] && echo "Curate: $LATEST_CURATE ($CURATE_PROMOTIONS promotions, $CURATE_ARCHIVES archives)"
[[ -n "$ASSESS_LINE" && "$ASSESS_LINE" != "ALL_NORMAL" ]] && echo "Attention: $ASSESS_LINE"
[[ -n "$ADVISOR_EXPORT_WARN" ]] && echo "Attention: $ADVISOR_EXPORT_WARN"
[[ -n "$OUTCOMES_LINE" ]] && echo "Outcomes: $OUTCOMES_LINE"
[[ -n "$FRESHNESS_LINE" ]] && echo "Freshness: $FRESHNESS_LINE"
[[ -n "$VELOCITY_LINE" ]] && echo "Velocity: $VELOCITY_LINE"
[[ -n "$AUTO_RUN_SUMMARY" ]] && echo "Last autonomous: $AUTO_RUN_SUMMARY"
[[ -n "$CODEX_VERIFY_LINE" ]] && echo "Codex verify: $CODEX_VERIFY_LINE"
[[ -n "$SEAT_USAGE_LINE" ]] && echo "${SEAT_USAGE_AGENT:-Agent} usage: $SEAT_USAGE_LINE"
[[ -n "$PENDING_AUTO_LINES" ]] && echo "Pending auto: $(echo "$PENDING_AUTO_LINES" | wc -l | tr -d ' ') branch(es)"
[[ -n "$GATE_SUMMARY" ]] && echo "Gates: $GATE_SUMMARY"
[[ $MEMORY_TOTAL -gt 0 ]] && echo "Memory: $MEMORY_LINE"
[[ -n "$PROOF_LINE" ]] && echo "Proof: $PROOF_LINE"
[[ -n "$PROOF_MISSING_WARN" ]] && echo "PROOF WARNING: $PROOF_MISSING_WARN"
echo "Suggested action: $SUGGESTED_ACTION"
} | tee "$_SESSION_BRIEF"
echo "[brain-resume] Session brief written to $_SESSION_BRIEF"
else
echo "[brain-resume] Close-refresh mode: skipped startup derivatives (active-context.compact, digest-preamble, session-start-contract, session-brief)"
fi
