import re, os, sys
from datetime import datetime, timezone

src, dst = sys.argv[1], sys.argv[2]
with open(src) as f:
    content = f.read()

now = datetime.now(timezone.utc).strftime("%Y-%m-%d")

# Extract sections
def extract(pattern, text, dotall=False):
    flags = re.DOTALL if dotall else 0
    m = re.search(pattern, text, flags)
    return m.group(1).strip() if m else ""

mission = extract(r'## North Star\s*\n\s*\n(.+?)(?:\n\n|\n##)', content, dotall=True)

# Focus: condense each bullet to shorter form
focus_raw = extract(r'## Current Focus Areas\s*\n((?:- .+\n?)+)', content)
focus_lines = [l.strip() for l in focus_raw.split('\n') if l.strip().startswith('- ')]

# Nodes table
nodes = []
in_table = False
for line in content.split('\n'):
    if line.startswith('| Node'):
        in_table = True
        continue
    if in_table and line.startswith('|---'):
        continue
    if in_table and line.startswith('|'):
        cols = [c.strip() for c in line.split('|')]
        if len(cols) >= 3:
            name, status = cols[1], cols[2]
            if name:
                nodes.append((name, status))
    elif in_table and not line.startswith('|'):
        break

# Founder
founder = extract(r'## Founder\s*\n((?:- .+\n?)+)', content)
# Condense founder to one line
founder_line = ""
for line in founder.split('\n'):
    if 'Name:' in line:
        founder_line = re.sub(r'- \*\*Name:\*\* ', '', line.strip())
        break

# Build compact
out = []
out.append("---")
out.append(f'title: "Active Context (compact)"')
out.append('type: "index"')
out.append('status: "active"')
out.append(f'last_updated: "{now}"')
out.append(f'full_file: "brain/index/active-context.md"')
out.append('generated: true')
out.append("---")
out.append("")
out.append("# Active Context (compact)")
out.append("")
out.append("> Auto-generated from `brain/index/active-context.md`. Full context there.")
out.append("")
out.append("## North Star")
out.append("")
out.append(mission if mission else "_Could not extract_")
out.append("")
out.append("## Current Focus")
out.append("")
for fl in focus_lines:
    out.append(fl)
out.append("")
out.append(f"## Active Nodes ({len(nodes)})")
out.append("")
out.append("| Node | Status |")
out.append("|------|--------|")
for name, status in nodes:
    out.append(f"| {name} | {status} |")
out.append("")
if founder_line:
    out.append(f"## Founder")
    out.append("")
    out.append(founder_line)
    out.append("")

with open(dst, 'w') as f:
    f.write('\n'.join(out))

PYAC
fi
fi

