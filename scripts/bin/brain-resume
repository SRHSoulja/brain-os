PROOF_LINE=""
_PROOF_LATEST="$BRAIN/brain/ops/proof-execution/index/latest.json"
if [[ -f "$_PROOF_LATEST" ]]; then
  PROOF_LINE=$(python3 -c "
import json
with open('$_PROOF_LATEST') as f:
    d = json.load(f)
v = d.get('verdict', d.get('status', 'unknown'))
print(f\"{v} ({d.get('run_id','?')}) | task={d.get('task_id','?')} executor={d.get('executor','?')}\")
" 2>/dev/null) || true
fi

# ── Proof presence check (strict, read-only) ─────────────────────
# If any active AI-owned task has a proof run but no verified summary, warn.
PROOF_MISSING_WARN=""
_ACTIVE_DIR="$BRAIN/brain/ops/tasks/active"
_PROOF_RUNS="$BRAIN/brain/ops/proof-execution/runs"
if [[ -d "$_ACTIVE_DIR" ]]; then
  for _af in "$_ACTIVE_DIR"/*.run.json; do
    [[ -f "$_af" ]] || continue
    _proof_rid=$(python3 -c "import json; d=json.load(open('$_af')); print(d.get('proof_run_id',''))" 2>/dev/null) || true
    if [[ -n "$_proof_rid" ]]; then
      _summary="$_PROOF_RUNS/${_proof_rid}.summary.json"
      if [[ ! -f "$_summary" ]]; then
        _task_id=$(python3 -c "import json; print(json.load(open('$_af')).get('task_id','?'))" 2>/dev/null)
        PROOF_MISSING_WARN="Active task $_task_id has proof run $_proof_rid but NO verified summary. Run: brain-proof-verify --run $_proof_rid"
      else
        _verdict=$(python3 -c "import json; print(json.load(open('$_summary')).get('verdict',''))" 2>/dev/null) || true
        if [[ "$_verdict" == "FAIL" ]]; then
          _task_id=$(python3 -c "import json; print(json.load(open('$_af')).get('task_id','?'))" 2>/dev/null)
          PROOF_MISSING_WARN="Active task $_task_id has FAILED proof run $_proof_rid. Fix and re-verify: brain-proof-verify --run $_proof_rid"
        fi
      fi
    fi
  done
fi

