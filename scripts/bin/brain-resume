    _df_status=$(grep -m1 '^status:' "$df" 2>/dev/null | sed 's/^status:\s*//;s/^"//;s/"$//' || true)
    [[ "$_df_status" != "pending" ]] && continue
    _df_title=$(grep -m1 '^# ' "$df" 2>/dev/null | sed 's/^# //' || true)
    _df_window=$(grep -m1 '^recommended_window:' "$df" 2>/dev/null | sed 's/^recommended_window:\s*//;s/^"//;s/"$//' || true)
    _df_exec=$(grep -m1 '^execution:' "$df" 2>/dev/null | sed 's/^execution:\s*//;s/^"//;s/"$//' || true)
    _df_exec_label=""
    [[ -n "$_df_exec" ]] && _df_exec_label=" [${_df_exec}]"
    [[ -n "$_df_title" ]] && _DEFERRED_LINES="${_DEFERRED_LINES}- ${_df_title} _(window: ${_df_window})_${_df_exec_label}
"
  done
  if [[ -n "$_DEFERRED_LINES" ]]; then
    DEFERRED_SECTION="### Deferred Actions

${_DEFERRED_LINES}"
  fi
fi

# ── Read decision patterns ────────────────────────────────────────
PATTERNS_DIR="$BRAIN/brain/ops/patterns"
PATTERNS_SECTION=""
if [[ -d "$PATTERNS_DIR" ]]; then
  _PATTERN_NAMES=""
  for pf in "$PATTERNS_DIR"/*.md; do
    [[ -f "$pf" ]] || continue
    _pn=$(grep -m1 '^name:' "$pf" 2>/dev/null | sed 's/^name:\s*//;s/^"//;s/"$//' || true)
    [[ -z "$_pn" ]] && _pn=$(basename "$pf" .md | tr '-' ' ')
    if [[ -n "$_PATTERN_NAMES" ]]; then
      _PATTERN_NAMES="${_PATTERN_NAMES} | ${_pn}"
    else
      _PATTERN_NAMES="$_pn"
    fi
  done
  if [[ -n "$_PATTERN_NAMES" ]]; then
    PATTERNS_SECTION="## Decision Patterns

${_PATTERN_NAMES}
"
  fi
fi

# ── Read compiled insights (last 10) ──────────────────────────────
INSIGHTS_FILE="$BRAIN/brain/ops/compiled-insights.md"
INSIGHTS_SECTION=""
if [[ -f "$INSIGHTS_FILE" ]]; then
  # Extract bullet lines (insights are "- " prefixed), take last 3
  _RECENT_INSIGHTS=$(grep '^\- ' "$INSIGHTS_FILE" | tail -3)
  if [[ -n "$_RECENT_INSIGHTS" ]]; then
    _INSIGHT_COUNT=$(echo "$_RECENT_INSIGHTS" | wc -l | tr -d ' ')
    INSIGHTS_SECTION="## Compiled Insights (last ${_INSIGHT_COUNT})

${_RECENT_INSIGHTS}

_Full list: brain/ops/compiled-insights.md_
"
  fi
fi

# ── Brain-native gate runner (fast, non-blocking) ─────────────────
# Runs core gates, captures verdicts for resume output.
# Non-blocking: WARN is informational, only FAIL is surfaced prominently.
# Migrated from codex-lab/experiments on 2026-04-17.
GATE_SUMMARY=""
GATE_REPORT_PATHS=""
_GATES="$BRAIN/scripts/bin"
if [[ -d "$_GATES" ]]; then
  _gate_contract=""
  _gate_integrity=""
  _gate_transport=""
  _gate_transport_rc=""

  # Gate 1: Brain/Body contract
  if [[ -x "$_GATES/brain-gate-contract-check.sh" ]]; then
    _g1_out=$(bash "$_GATES/brain-gate-contract-check.sh" 2>/dev/null) || true
    _gate_contract=$(echo "$_g1_out" | grep -oP '(?<=brain-body-contract-check: )\w+' || echo "ERROR")
    _g1_report=$(echo "$_g1_out" | grep -oP '(?<=Wrote: ).*' || true)
    [[ -n "$_g1_report" ]] && GATE_REPORT_PATHS="${GATE_REPORT_PATHS}\n  contract: $_g1_report"
  fi

  # Gate 2: Repo integrity
  if [[ -x "$_GATES/brain-gate-repo-integrity.sh" ]]; then
    _g2_out=$(bash "$_GATES/brain-gate-repo-integrity.sh" 2>/dev/null) || true
    _gate_integrity=$(echo "$_g2_out" | grep -oP '(?<=brain-repo-integrity-gate: )\w+' || echo "ERROR")
    _g2_report=$(echo "$_g2_out" | grep -oP '(?<=Wrote: ).*' || true)
    [[ -n "$_g2_report" ]] && GATE_REPORT_PATHS="${GATE_REPORT_PATHS}\n  integrity: $_g2_report"
  fi

  # Public repo isolation: transport/VE gates are intentionally disabled.

  # Build summary line
  _gate_items=()
  [[ -n "$_gate_contract" ]] && _gate_items+=("contract=$_gate_contract")
  [[ -n "$_gate_integrity" ]] && _gate_items+=("integrity=$_gate_integrity")

  # Memory integrity gate (optional, non-blocking)
  _gate_memory=""
  MEM_GATE="$_GATES/brain-gate-memory-integrity.sh"
  if [[ -x "$MEM_GATE" ]]; then
    _mg_out=$("$MEM_GATE" 2>/dev/null || true)
    _gate_memory=$(echo "$_mg_out" | grep -oP '(?<=memory-integrity-gate: )\w+' || echo "SKIP")
    _mg_report=$(echo "$_mg_out" | head -1)
    [[ -n "$_mg_report" ]] && GATE_REPORT_PATHS="${GATE_REPORT_PATHS}\n  memory: $_mg_report"
  fi
  [[ -n "$_gate_memory" && "$_gate_memory" != "SKIP" ]] && _gate_items+=("memory=$_gate_memory")

  GATE_SUMMARY=$(IFS=', '; echo "${_gate_items[*]}")

  # Check for any FAIL
  _gate_has_fail=false
  for _gv in "$_gate_contract" "$_gate_integrity"; do
    [[ "$_gv" == FAIL* ]] && _gate_has_fail=true
  done
fi

# ── Core-memory queue check ───────────────────────────────────────
CORE_MEM_LINE=""
_CMEM_QUEUE="$BRAIN/brain/ops/core-memory/queue.jsonl"
if [[ -f "$_CMEM_QUEUE" ]] && command -v brain-core-memory-status >/dev/null 2>&1; then
  _cmem_count=$(brain-core-memory-status --count-only 2>/dev/null || echo "0")
  if [[ "$_cmem_count" -gt 0 ]]; then
    _cmem_top=$(brain-core-memory-status 2>/dev/null | grep '^\s*- \[' | head -3 | sed 's/^  //' || true)
    CORE_MEM_LINE="$_cmem_count unresolved"
  else
    CORE_MEM_LINE="0 unresolved"
  fi
fi

# ── Seat usage snapshot (agent-agnostic) ──────────────────────────
# Reads seat-usage-snapshot.json (normalized v1 schema from brain-seat-usage-snapshot).
# Labels output with actual agent name. Tiered staleness: <=30m fresh, 30m-2h stale, >2h unreliable.
# Refresh first so we read the current active seat, not a stale prior agent's snapshot.
"$TOOLS/bin/brain-seat-usage-snapshot" --quiet 2>/dev/null || true
SEAT_USAGE_LINE=""
SEAT_USAGE_AGENT=""
_SEAT_USAGE="$BRAIN/work/logs/seat-usage-snapshot.json"
if [[ -f "$_SEAT_USAGE" ]]; then
  read -r SEAT_USAGE_AGENT SEAT_USAGE_LINE < <(python3 - "$_SEAT_USAGE" <<'PY'
import json,sys,time
from datetime import datetime, timezone
path=sys.argv[1]
try:
    d=json.load(open(path))
except Exception:
    print("unknown ")
    raise SystemExit
agent=d.get("agent","unknown")
def parse_iso(s):
    if not s: return None
    try: return datetime.fromisoformat(s.replace("Z","+00:00"))
    except Exception: return None
last_raw=d.get("last_activity_at") or d.get("captured_at") or ""
last_dt=parse_iso(last_raw)
age_min=None
if last_dt is not None:
    age_min=(datetime.now(timezone.utc)-last_dt).total_seconds()/60
stale_marker=""
if age_min is None:
    stale_marker=" (no timestamp)"
elif age_min > 120:
    hrs=age_min/60
    label=f"{hrs:.1f}h" if hrs < 48 else f"{hrs/24:.1f}d"
    print(f"{agent} stale ({label} old)")
    raise SystemExit
elif age_min > 30:
    stale_marker=f" (stale {int(age_min)}m)"
def countdown(resets_at):
    if not resets_at: return ""
    try: remaining=int(resets_at)-int(time.time())
    except Exception: return ""
    if remaining<=0: return ""
    days,remaining=divmod(remaining,86400)
    hours,remaining=divmod(remaining,3600)
    mins=remaining//60
    if days>0: return f"({days}d{hours}h)"
    if hours>0: return f"({hours}h{mins:02d}m)"
    return f"({mins}m)"
parts=[]
rl=d.get("rate_limits") or {}
short=(rl.get("short_window") or {})
long_w=(rl.get("long_window") or {})
# claude-code: seat-usage-snapshot returns null rate_limits (JSONL adapter can't read them).
# Fall back to usage-snapshot.json (statusline path) which has authoritative 5h/7d windows.
if agent == "claude-code" and short.get("used_percent") is None and long_w.get("used_percent") is None:
    import os
    _sl_path = os.path.join(os.path.dirname(path), "usage-snapshot.json")
    try:
        _sl = json.load(open(_sl_path))
        _sl_rl = _sl.get("rate_limits") or {}
        _fh = _sl_rl.get("five_hour") or {}
        _7d = _sl_rl.get("seven_day") or {}
        if _fh.get("used_percentage") is not None:
            short = {"used_percent": _fh["used_percentage"], "window_label": "5h", "resets_at": _fh.get("resets_at")}
        if _7d.get("used_percentage") is not None:
            long_w = {"used_percent": _7d["used_percentage"], "window_label": "7d", "resets_at": _7d.get("resets_at")}
    except Exception:
        pass
if short.get("used_percent") is not None:
    lbl=short.get("window_label","short")
    parts.append(f"{lbl} {short['used_percent']}% {countdown(short.get('resets_at'))}".rstrip())
if long_w.get("used_percent") is not None:
    lbl=long_w.get("window_label","long")
    parts.append(f"{lbl} {long_w['used_percent']}% {countdown(long_w.get('resets_at'))}".rstrip())
ctx=(d.get("context_window") or {}).get("used_percent")
if ctx is not None: parts.append(f"ctx {ctx}%")
tok=(d.get("tokens") or {}).get("total")
if tok is not None:
    if tok>=1000000: parts.append(f"{tok/1000000:.1f}M tok")
    elif tok>=1000: parts.append(f"{tok/1000:.0f}k tok")
    else: parts.append(f"{tok} tok")
last=d.get("last_activity_at","")
if last: parts.append(f"last {last[11:16]}Z")
line=" | ".join(parts)
if line and stale_marker: line=f"{line}{stale_marker}"
print(f"{agent} {line}")
PY
) || true
fi

# ── Memory-wiki consistency check ─────────────────────────────────
# Counts memory files with and without matching wiki pages.
MEMORY_MAPPED=0
MEMORY_UNMAPPED=0
MEMORY_UNMAPPED_LIST=""
_MEMORY_DIR="$BRAIN/brain/memory"
_WIKI_PAGES="$BRAIN/brain/wiki/pages"
_WIKI_SYSTEMS="$BRAIN/brain/wiki/systems"
if [[ -d "$_MEMORY_DIR" ]]; then
  for _mf in "$_MEMORY_DIR"/*.md; do
    _mbase=$(basename "$_mf")
    [[ "$_mbase" == "MEMORY.md" ]] && continue
    if [[ -f "$_WIKI_PAGES/$_mbase" || -f "$_WIKI_SYSTEMS/$_mbase" ]]; then
      MEMORY_MAPPED=$((MEMORY_MAPPED + 1))
    else
      MEMORY_UNMAPPED=$((MEMORY_UNMAPPED + 1))
      MEMORY_UNMAPPED_LIST="${MEMORY_UNMAPPED_LIST}${_mbase}\n"
    fi
  done
fi
MEMORY_TOTAL=$((MEMORY_MAPPED + MEMORY_UNMAPPED))
MEMORY_LINE="$MEMORY_MAPPED/$MEMORY_TOTAL mapped"
[[ $MEMORY_UNMAPPED -gt 0 ]] && MEMORY_LINE="$MEMORY_LINE, $MEMORY_UNMAPPED unmapped"

