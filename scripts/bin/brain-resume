" 2>/dev/null || true)
fi

# ── 4. Inbox items ─────────────────────────────────────────────────
INBOX_COUNT=0
INBOX_FILES=""
if [[ -d "$BRAIN/work/inbox" ]]; then
  while IFS= read -r f; do
    name=$(basename "$f")
    [[ "$name" == "README.md" || "$name" == ".gitkeep" ]] && continue
    INBOX_COUNT=$((INBOX_COUNT + 1))
    INBOX_FILES="$INBOX_FILES\n- \`$name\`"
  done < <(find "$BRAIN/work/inbox" -maxdepth 1 -type f 2>/dev/null)
fi

# ── 5. Pending deletions ──────────────────────────────────────────
PENDING_COUNT=0
PENDING_FILES=""
if [[ -d "$BRAIN/work/inbox/pending-deletions" ]]; then
  while IFS= read -r f; do
    name=$(basename "$f")
    [[ "$name" == ".gitkeep" ]] && continue
    if grep -q 'status: pending' "$f" 2>/dev/null; then
      PENDING_COUNT=$((PENDING_COUNT + 1))
      PENDING_FILES="$PENDING_FILES\n- \`$name\` — awaiting confirmation"
    fi
  done < <(find "$BRAIN/work/inbox/pending-deletions" -maxdepth 1 -type f 2>/dev/null)
fi

