  fi
fi

# ── 8e1. Review state ─────────────────────────────────────────────
REVIEW_STATE_FILE="$BRAIN/brain/ops/review-state.md"
REVIEW_JSON_FILE="$BRAIN/brain/ops/review-state.json"
REVIEW_TRIAGE_DATE=""
REVIEW_TRIAGE_AGE=""
REVIEW_WEEKLY_DATE=""
REVIEW_WEEKLY_AGE=""
REVIEW_NEXT_DUE=""
_review_output=""
# Prefer JSON sidecar (reliable), fall back to markdown regex
if [[ -f "$REVIEW_JSON_FILE" ]]; then
  _review_output=$(python3 - "$REVIEW_JSON_FILE" <<'PYEOF'
import json, sys
from datetime import datetime

path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
except:
    sys.exit(1)

def age_label(date_str):
    if not date_str or date_str.startswith('_') or date_str == 'never':
        return 'NEVER'
    try:
        dt = datetime.strptime(date_str[:10], '%Y-%m-%d')
        age = (datetime.now() - dt).days
        if age == 0: return 'today'
        elif age == 1: return '1d ago'
        elif age <= 7: return f'{age}d ago'
        else: return f'{age}d ago — OVERDUE'
    except:
        return '?'

triage_date = data.get('triage', {}).get('date', '')
weekly_date = data.get('weekly', {}).get('date', '')
next_due = data.get('weekly', {}).get('next_due', '')

print(f'{triage_date}\t{age_label(triage_date)}\t{weekly_date}\t{age_label(weekly_date)}\t{next_due}')
PYEOF
  ) || true
fi
# Fallback: parse markdown if JSON missing or failed
if [[ -z "$_review_output" && -f "$REVIEW_STATE_FILE" ]]; then
  _review_output=$(python3 - "$REVIEW_STATE_FILE" <<'PYEOF'
import sys, re
from datetime import datetime

path = sys.argv[1]
with open(path, 'r') as f:
    content = f.read()

def extract(section, field):
    pattern = rf'## {section}\n\n(?:.*\n)*?- \*\*{field}:\*\* (.*)'
    m = re.search(pattern, content)
    return m.group(1).strip() if m else ''

def age_label(date_str):
    if not date_str or date_str.startswith('_') or date_str == 'never':
        return 'NEVER'
    try:
        dt = datetime.strptime(date_str[:10], '%Y-%m-%d')
        age = (datetime.now() - dt).days
        if age == 0: return 'today'
        elif age == 1: return '1d ago'
        elif age <= 7: return f'{age}d ago'
        else: return f'{age}d ago — OVERDUE'
    except:
        return '?'

triage_date = extract('Last Inbox Triage', 'date')
weekly_date = extract('Last Weekly Review', 'date')
next_due = extract('Last Weekly Review', 'next_due')

print(f'{triage_date}\t{age_label(triage_date)}\t{weekly_date}\t{age_label(weekly_date)}\t{next_due}')
PYEOF
  ) || true
fi
if [[ -n "$_review_output" ]]; then
  IFS=$'\t' read -r REVIEW_TRIAGE_DATE REVIEW_TRIAGE_AGE REVIEW_WEEKLY_DATE REVIEW_WEEKLY_AGE REVIEW_NEXT_DUE <<< "$_review_output"
elif [[ ! -f "$REVIEW_STATE_FILE" && ! -f "$REVIEW_JSON_FILE" ]]; then
  REVIEW_TRIAGE_AGE="NO FILE"
  REVIEW_WEEKLY_AGE="NO FILE"
fi

# ── 8e. Curate report ─────────────────────────────────────────────
CURATE_DIR="$BRAIN/work/inbox/curate-reports"
