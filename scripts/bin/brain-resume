  _adv_mtime=$(stat -c %Y "$_advisor_ctx" 2>/dev/null || echo 0)
  _adv_age_days=$(( ($(date +%s) - _adv_mtime) / 86400 ))
  if [[ "$_adv_age_days" -ge 7 ]]; then
    _arch_newer=0
    for _adir in "$BRAIN/brain/wiki/principles" "$BRAIN/brain/wiki/systems"; do
      if [[ -d "$_adir" ]]; then
        _arch_newer=$(( _arch_newer + $(find "$_adir" -type f -newer "$_advisor_ctx" 2>/dev/null | wc -l) ))
      fi
    done
    if [[ "$_arch_newer" -gt 0 ]]; then
      ADVISOR_EXPORT_WARN="Advisor context export is ${_adv_age_days}d old; ${_arch_newer} architecture files changed since. Run brain-export-context --single."
    fi
  fi
