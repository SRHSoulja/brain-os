# ── 8a. Active tasks (brain-task CLI) ─────────────────────────────
TASKS_DIR="$BRAIN/work/tasks"
ACTIVE_TASKS=""
ACTIVE_TASK_COUNT=0
BLOCKED_TASK_COUNT=0
if [[ -d "$TASKS_DIR" ]]; then
  for tf in "$TASKS_DIR"/task-*.md; do
    [[ -f "$tf" ]] || continue
    t_status=$(fm_get "$tf" "status")
    t_title=$(fm_get "$tf" "title")
    t_priority=$(fm_get "$tf" "priority")
    if [[ "$t_status" == "active" ]]; then
      ACTIVE_TASKS="${ACTIVE_TASKS}\n- **[$t_priority] $t_title** (\`$(basename "$tf")\`)"
      ACTIVE_TASK_COUNT=$((ACTIVE_TASK_COUNT + 1))
    elif [[ "$t_status" == "blocked" ]]; then
      ACTIVE_TASKS="${ACTIVE_TASKS}\n- **[$t_priority] $t_title** (\`$(basename "$tf")\`) — BLOCKED"
      BLOCKED_TASK_COUNT=$((BLOCKED_TASK_COUNT + 1))
    fi
  done
fi

# ── 8a2. Task queue (brain/ops/tasks/) ───────────────────────────
OPS_TASKS_DIR="$BRAIN/brain/ops/tasks"
OPS_QUEUED_COUNT=0
OPS_ACTIVE_COUNT=0
OPS_ACTIVE_LIST=""
OPS_COMPLETED_COUNT=0
if [[ -d "$OPS_TASKS_DIR" ]]; then
  for tf in "$OPS_TASKS_DIR"/queue/TASK-*.md; do
    [[ -f "$tf" ]] || continue
    # Skip parked tasks — they live in queue/ but are not actionable
    grep -q '^status:[[:space:]]*parked' "$tf" && continue
    OPS_QUEUED_COUNT=$((OPS_QUEUED_COUNT + 1))
  done
  OPS_ORPHAN_LIST=""
  OPS_ORPHAN_COUNT=0
  for tf in "$OPS_TASKS_DIR"/active/TASK-*.md; do
    [[ -f "$tf" ]] || continue
    OPS_ACTIVE_COUNT=$((OPS_ACTIVE_COUNT + 1))
    t_id=$(fm_get "$tf" "task_id")
    t_priority=$(fm_get "$tf" "priority")
    t_owner=$(fm_get "$tf" "owner")
    t_title=$(head -30 "$tf" | grep '^# ' | head -1 | sed 's/^# //' || true)
    # Orphan detection: task is orphaned if it's been in active/ for >2h
    # Primary signal: claimed_at from frontmatter, fallback: launched_at from run record
    _is_orphan=false
    _age_hours=0
    _claimed_at=$(fm_get "$tf" "claimed_at")
    _run_record="$OPS_TASKS_DIR/active/${t_id}.run.json"
    _timestamp=""
    if [[ -n "$_claimed_at" ]]; then
      _timestamp="$_claimed_at"
    elif [[ -f "$_run_record" ]]; then
      _timestamp=$(python3 -c "import json; print(json.load(open('$_run_record')).get('launched_at',''))" 2>/dev/null) || true
    fi
    if [[ -n "$_timestamp" ]]; then
      _claim_epoch=$(date -d "$_timestamp" +%s 2>/dev/null || echo 0)
      _now_epoch=$(date +%s)
      _age_hours=$(( (_now_epoch - _claim_epoch) / 3600 ))
      # Orphan if >2h old -- the agent session that claimed it is almost certainly gone
      if [[ $_age_hours -ge 2 ]]; then
        _is_orphan=true
      fi
    fi
    if $_is_orphan; then
      OPS_ORPHAN_COUNT=$((OPS_ORPHAN_COUNT + 1))
      OPS_ORPHAN_LIST="${OPS_ORPHAN_LIST}\n- **ORPHAN [$t_priority] $t_title** (\`$t_id\`, owner: $t_owner, claimed ${_age_hours}h ago) → release: \`brain-task-release $t_id --reason \"session ended without completion\"\`"
      OPS_ACTIVE_LIST="${OPS_ACTIVE_LIST}\n- **ORPHAN [$t_priority] $t_title** (\`$t_id\`, owner: $t_owner) — claimed ${_age_hours}h ago, process dead"
    else
      OPS_ACTIVE_LIST="${OPS_ACTIVE_LIST}\n- **[$t_priority] $t_title** (\`$t_id\`, owner: $t_owner)"
    fi
  done
  for tf in "$OPS_TASKS_DIR"/completed/TASK-*.md; do
    [[ -f "$tf" ]] || continue
    OPS_COMPLETED_COUNT=$((OPS_COMPLETED_COUNT + 1))
  done
fi

