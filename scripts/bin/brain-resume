# ── Last autonomous run summary (read-only) ──────────────────────
AUTO_RUN_SUMMARY=""
_auto_log="$BRAIN/work/logs/autonomous-run.log"
if [[ -f "$_auto_log" ]]; then
  AUTO_RUN_SUMMARY=$(python3 - "$BRAIN" <<'PYEOF'
import re, sys, os
brain = sys.argv[1]
log_path = os.path.join(brain, "work/logs/autonomous-run.log")
if not os.path.isfile(log_path):
    sys.exit(0)
with open(log_path) as f:
    lines = f.readlines()
if not lines:
    sys.exit(0)
start_ts = verdict = signal_eval = task_exec = ""
for line in lines:
    line = line.strip()
    if "AUTONOMOUS_START" in line:
        start_ts = line.split()[0] if line else ""
    elif "VERDICT_OK" in line:
        m = re.search(r"age=(\S+)", line)
        verdict = f"OK ({m.group(1)})" if m else "OK"
    elif "VERDICT_FAIL" in line:
        m = re.search(r"status=(\S+)|stale=(\S+)", line)
        verdict = f"FAIL ({m.group(0)})" if m else "FAIL"
    elif "SIGNAL_EVAL" in line:
        m = re.search(r"value=(\S+) level=(\S+)", line)
        if m: signal_eval = f"deploy_age={m.group(1)} ({m.group(2)})"
    elif "SIGNAL_SKIP" in line:
        m = re.search(r"reason=(\S+)", line)
        if m: signal_eval = f"skip ({m.group(1)})"
    elif "SIGNAL_THRESHOLD_MATCH" in line:
        m = re.search(r"level=(\S+) value=(\S+)", line)
        if m: signal_eval = f"MATCH {m.group(1)} ({m.group(2)}h)"
    elif "TASK_COMPLETED" in line:
        m = re.search(r"task_id=(\S+)", line)
        if m: task_exec = m.group(1)
    elif "SCAN_NO_ELIGIBLE" in line or "SCAN_EMPTY" in line:
        task_exec = "no-op"
parts = []
if start_ts: parts.append(start_ts[:10])
if verdict: parts.append(verdict)
if signal_eval: parts.append(f"signal: {signal_eval}")
if task_exec: parts.append(f"exec: {task_exec}")
if parts: print(" | ".join(parts))
PYEOF
  ) || true
fi

# ── Pending autonomous branches (read-only) ──────────────────────
PENDING_AUTO_LINES=""
_pending_auto_head=""
_pending_auto_branch=""
if git remote 2>/dev/null | grep -q origin; then
  git fetch origin --prune 2>/dev/null || true
  _auto_refs=$(git for-each-ref --sort=-committerdate --format='%(refname:short)|%(committerdate:short)|%(subject)' refs/remotes/origin/auto/ 2>/dev/null)
  if [[ -n "$_auto_refs" ]]; then
    # Extract head commit of newest auto branch for Codex verdict lookup
    _newest_auto_ref=$(echo "$_auto_refs" | head -1 | cut -d'|' -f1)
    _pending_auto_head=$(git rev-parse --short "$_newest_auto_ref" 2>/dev/null || true)
    _pending_auto_branch="${_newest_auto_ref#origin/}"
    PENDING_AUTO_LINES=$(echo "$_auto_refs" | while IFS='|' read -r ref date subject; do
      branch="${ref#origin/}"
      count=$(git rev-list --count "origin/main..${ref}" 2>/dev/null || echo "?")
      echo "${branch} -- ${subject} (${count} commit(s), ${date})"
    done)
  fi
fi

