# ── Build session arc narrative ────────────────────────────────────
SESSION_ARC=""
SESSION_ARC=$(python3 -c "
import os, re, sys
from datetime import datetime, timezone

brain = sys.argv[1]
lines = []

# 1. Recent devlog titles (last 3, newest by frontmatter date then mtime tiebreaker)
devlog_dir = os.path.join(brain, 'work/logs/devlog')
devlogs = []
if os.path.isdir(devlog_dir):
    candidates = []
    for f in os.listdir(devlog_dir):
        if f.startswith('2026-') and f.endswith('.md') and f != 'README.md':
            path = os.path.join(devlog_dir, f)
            with open(path) as fh:
                content = fh.read()
            dm = re.search(r'^date:\s*\"(.+?)\"', content, re.MULTILINE)
            fm_date = dm.group(1) if dm else f[:10]
            # Sort key: frontmatter date (primary), mtime (tiebreaker within same date)
            candidates.append((fm_date, os.path.getmtime(path), f, path, content))
    candidates.sort(key=lambda c: (c[0], c[1]), reverse=True)
    for fm_date, _, f, path, content in candidates[:3]:
        m = re.search(r'^title:\s*\"(.+?)\"', content, re.MULTILINE)
        title = m.group(1) if m else f.replace('.md', '')
        devlogs.append((fm_date, title))

if devlogs:
    latest_date, latest_title = devlogs[0]
    lines.append(f'Last session shipped **{latest_title}** ({latest_date}).')

# 2. Waiting-on-human items (from queue: human-owned tasks, or known pending actions)
queue_dir = os.path.join(brain, 'brain/ops/tasks/queue')
human_waiting = []
if os.path.isdir(queue_dir):
    for f in sorted(os.listdir(queue_dir)):
        if not f.startswith('TASK-') or not f.endswith('.md'):
            continue
        path = os.path.join(queue_dir, f)
        with open(path) as fh:
            content = fh.read()
        am = re.search(r'\*\*authority_owner:\*\*\s*(\S+)', content)
        if am and am.group(1) == 'human':
            tm = re.search(r'^# (.+)$', content, re.MULTILINE)
            title = tm.group(1) if tm else f
            human_waiting.append(title)

# 3. Latest handoff note (if exists and recent)
handoff_dir = os.path.join(brain, 'work/session-handoffs')
if os.path.isdir(handoff_dir):
    handoffs = sorted([f for f in os.listdir(handoff_dir) if f.endswith('.md')], reverse=True)
    if handoffs:
        hf_path = os.path.join(handoff_dir, handoffs[0])
        # Only include if less than 3 days old
        mtime = os.path.getmtime(hf_path)
        age_hours = (datetime.now(timezone.utc).timestamp() - mtime) / 3600
        if age_hours < 72:
            with open(hf_path) as fh:
                hc = fh.read()
            # Extract first non-empty, non-frontmatter line as the handoff note
            in_frontmatter = False
            for line in hc.split('\n'):
                if line.strip() == '---':
                    in_frontmatter = not in_frontmatter
                    continue
                if in_frontmatter:
                    continue
                stripped = line.strip()
                if stripped and not stripped.startswith('#'):
                    lines.append(f'Handoff note: {stripped}')
                    break

# 4. Execution notes removed from resume (available in devlog)

if human_waiting:
    lines.append('Waiting on you: ' + '; '.join(human_waiting[:3]) + '.')

if lines:
    print('\n'.join(lines))
else:
    print('')
" "$BRAIN" 2>/dev/null || true)

# ── Read recent healing events ─────────────────────────────────────
HEALING_LOG="$BRAIN/work/logs/healing-events.log"
HEALING_SECTION=""
HEALING_PRIORITY=""
HEALING_ACTIVE=false
if [[ -f "$HEALING_LOG" ]]; then
  # Only show entries from last 48h (prevents stale resolved signals from lingering)
  _HEAL_CUTOFF=$(date -u -d '48 hours ago' +%Y-%m-%dT%H:%M 2>/dev/null || date -u -v-48H +%Y-%m-%dT%H:%M 2>/dev/null || echo "2000-01-01T00:00")
  RECENT_HEALING=$(awk -F'|' -v cutoff="$_HEAL_CUTOFF" '$1 >= cutoff' "$HEALING_LOG" 2>/dev/null | tail -3 || true)
  if [[ -n "$RECENT_HEALING" ]]; then
    # Detect active signals: DRIFT, CONFLICT, DEGRADED, or repeated remedies
    if echo "$RECENT_HEALING" | grep -qiE 'DRIFT|CONFLICT|DEGRADED'; then
      HEALING_ACTIVE=true
    fi
    # Check for repeated remedies (same remedy_id appearing 2+ times in last 5 entries)
    if [[ -f "$HEALING_LOG" ]]; then
      _REMEDY_DUPES=$(tail -5 "$HEALING_LOG" | grep '| remedy |' | awk -F'|' '{gsub(/^ +| +$/,"",$4); print $4}' | sort | uniq -d || true)
      [[ -n "$_REMEDY_DUPES" ]] && HEALING_ACTIVE=true
    fi

    # Compress to summary line: count total, count resolved
    _HEAL_TOTAL=$(echo "$RECENT_HEALING" | wc -l | tr -d ' ')
    _HEAL_RESOLVED=$(echo "$RECENT_HEALING" | grep -ci 'resolved' || true)
    HEALING_SECTION="### Healing Signals

${_HEAL_TOTAL} healing signal(s) in last 48h (${_HEAL_RESOLVED} resolved). See \`work/logs/healing-events.log\`.
"
  fi
fi

HEALING_CANDIDATES=""
if [[ "$HEALING_ACTIVE" == "true" ]]; then
  HEALING_PRIORITY=""

  # Generate healing candidates from detected patterns (max 2, template only)
  _HC_LINES=""
  _HC_COUNT=0

  # Repeated DRIFT/CONFLICT in recent events
  _DRIFT_COUNT=$(tail -10 "$HEALING_LOG" 2>/dev/null | grep -ciE 'DRIFT|CONFLICT' || true)
  if [[ $_DRIFT_COUNT -ge 2 && $_HC_COUNT -lt 2 ]]; then
    _DRIFT_SOURCE=$(tail -10 "$HEALING_LOG" | grep -iE 'DRIFT|CONFLICT' | tail -1 | awk -F'|' '{gsub(/^ +| +$/,"",$4); print $4}' || true)
    _HC_LINES="${_HC_LINES}- Investigate recurring drift: ${_DRIFT_SOURCE}
"
    _HC_COUNT=$((_HC_COUNT + 1))
  fi

  # Repeated remedies
  if [[ -n "${_REMEDY_DUPES:-}" && $_HC_COUNT -lt 2 ]]; then
    _HC_LINES="${_HC_LINES}- Review recurring remedy: ${_REMEDY_DUPES}
"
    _HC_COUNT=$((_HC_COUNT + 1))
  fi

  # DEGRADED state
  _DEG_COUNT=$(tail -10 "$HEALING_LOG" 2>/dev/null | grep -ciE 'DEGRADED' || true)
  if [[ $_DEG_COUNT -ge 1 && $_HC_COUNT -lt 2 ]]; then
    _DEG_SOURCE=$(tail -10 "$HEALING_LOG" | grep -iE 'DEGRADED' | tail -1 | awk -F'|' '{gsub(/^ +| +$/,"",$4); print $4}' || true)
    _HC_LINES="${_HC_LINES}- Stabilize: ${_DEG_SOURCE}
"
    _HC_COUNT=$((_HC_COUNT + 1))
  fi

  if [[ -n "$_HC_LINES" ]]; then
    HEALING_CANDIDATES="### Healing Candidates

${_HC_LINES}"
  fi
fi

# ── Read recent reflection status ──────────────────────────────────
REFLECT_DIR="$BRAIN/work/logs/reflections"
REFLECT_STATUS=""
if [[ -d "$REFLECT_DIR" ]]; then
  LATEST_REFLECT=$(ls -t "$REFLECT_DIR"/*-reflect.md 2>/dev/null | head -1 || true)
  LATEST_SKIP=$(ls -t "$REFLECT_DIR"/*-skipped.md 2>/dev/null | head -1 || true)
  if [[ -n "$LATEST_REFLECT" ]]; then
    REFLECT_DATE=$(basename "$LATEST_REFLECT" | sed 's/-reflect\.md//')
    REFLECT_AGE_DAYS=$(( ($(date +%s) - $(date -d "$REFLECT_DATE" +%s 2>/dev/null || echo $(date +%s))) / 86400 ))
    if [[ $REFLECT_AGE_DAYS -eq 0 ]]; then
      REFLECT_STATUS="- **Reflection:** Current session (\`$REFLECT_DATE\`)"
    elif [[ $REFLECT_AGE_DAYS -le 3 ]]; then
      REFLECT_STATUS="- **Reflection:** ${REFLECT_AGE_DAYS}d ago (\`$REFLECT_DATE\`)"
    else
      REFLECT_STATUS="- **Reflection:** ${REFLECT_AGE_DAYS}d ago (\`$REFLECT_DATE\`) — consider reflecting this session"
    fi
  elif [[ -n "$LATEST_SKIP" ]]; then
    SKIP_DATE=$(basename "$LATEST_SKIP" | sed 's/-skipped\.md//')
    REFLECT_STATUS="- **Reflection:** Last session skipped (\`$SKIP_DATE\`)"
  else
    REFLECT_STATUS="- **Reflection:** _never recorded_ — run \`brain-reflect\` to start"
  fi
else
  REFLECT_STATUS="- **Reflection:** _not yet initialized_"
fi

# Extract first meaningful line from latest reflection for carry-forward
REFLECT_ECHO=""
if [[ -n "${LATEST_REFLECT:-}" && -f "${LATEST_REFLECT:-}" ]]; then
  # Find first filled-in bullet from the "Reflect" section (after "## Reflect")
  REFLECT_ECHO=$(awk '
    /^## Reflect/ { in_reflect=1; next }
    !in_reflect { next }
    /^---$/ { exit }
    /^#/ { next }
    /^$/ { next }
    /^-$/ { next }
    /^\*Generated/ { next }
    /^- .+/ { print; exit }
  ' "$LATEST_REFLECT" 2>/dev/null || true)
  if [[ -n "$REFLECT_ECHO" ]]; then
    REFLECT_STATUS="${REFLECT_STATUS}
- **Last reflection insight:** ${REFLECT_ECHO}"
  fi

  # Parse "What should happen next" bullets as candidate tasks (raw pass-through)
  REFLECT_CANDIDATES=$(awk '
    /^### What should happen next/ { in_next=1; next }
    !in_next { next }
    /^#/ { exit }
    /^$/ { next }
    /^-$/ { next }
    /^- .+/ { print }
  ' "$LATEST_REFLECT" 2>/dev/null || true)
  if [[ -n "$REFLECT_CANDIDATES" ]]; then
    # Duplicate detection: grep candidate keywords against queue/active task titles
    TAGGED_CANDIDATES=""
    while IFS= read -r cand_line; do
      # Extract keywords (strip leading "- ", take first 4 words)
      cand_words=$(echo "$cand_line" | sed 's/^- //' | awk '{for(i=1;i<=4&&i<=NF;i++) printf "%s ", $i}' | xargs)
      match=""
      for task_dir in "$BRAIN/brain/ops/tasks/queue" "$BRAIN/brain/ops/tasks/active"; do
        [[ -d "$task_dir" ]] || continue
        for tf in "$task_dir"/TASK-*.md; do
          [[ -f "$tf" ]] || continue
          task_title=$(grep -m1 '^title:' "$tf" 2>/dev/null | sed 's/^title:\s*//;s/^"//;s/"$//' || true)
          task_id=$(grep -m1 '^task_id:' "$tf" 2>/dev/null | sed 's/^task_id:\s*//;s/^"//;s/"$//' || true)
          # Check if any keyword appears in the task title (case-insensitive)
          for w in $cand_words; do
            [[ ${#w} -lt 4 ]] && continue  # skip short words
            if echo "$task_title" | grep -qi "$w" 2>/dev/null; then
              match="$task_id"
              break 2
            fi
          done
        done
      done
      if [[ -n "$match" ]]; then
        TAGGED_CANDIDATES="${TAGGED_CANDIDATES}${cand_line} _(similar: ${match})_
"
      else
        TAGGED_CANDIDATES="${TAGGED_CANDIDATES}${cand_line}
"
      fi
    done <<< "$REFLECT_CANDIDATES"

    REFLECT_STATUS="${REFLECT_STATUS}

### Reflection Candidates

${TAGGED_CANDIDATES}"
  fi
fi

# ── Read persisted next-focus recommendation ──────────────────────
NEXT_FOCUS_FILE="$BRAIN/work/logs/next-focus-latest.json"
NEXT_FOCUS_SECTION=""
NEXT_FOCUS_STALE=false
if [[ -f "$NEXT_FOCUS_FILE" ]]; then
  # Read recommendation fields
  NF_SUMMARY=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('summary',''))" "$NEXT_FOCUS_FILE" 2>/dev/null || true)
  NF_GENERATED=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('generated_at','')[:19])" "$NEXT_FOCUS_FILE" 2>/dev/null || true)
  NF_FOCUS_TYPE=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('focus_type',''))" "$NEXT_FOCUS_FILE" 2>/dev/null || true)
  NF_FINGERPRINT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('queue_fingerprint',''))" "$NEXT_FOCUS_FILE" 2>/dev/null || true)
  NF_TOP_TASKS=$(python3 -c "
import json,sys
d=json.load(open(sys.argv[1]))
recs=d.get('recommendations',[])
if recs and 'tasks' in recs[0]:
    print(', '.join(recs[0]['tasks'][:3]))
else:
    print('')
" "$NEXT_FOCUS_FILE" 2>/dev/null || true)

  if [[ -n "$NF_SUMMARY" ]]; then
    # Check staleness: recompute current queue fingerprint and compare
    CURRENT_FP=$(python3 -c "
import os, re, sys
queue_dir = os.path.join(sys.argv[1], 'brain/ops/tasks/queue')
tasks = []
if os.path.isdir(queue_dir):
    for f in sorted(os.listdir(queue_dir)):
        if f.startswith('TASK-') and f.endswith('.md'):
            path = os.path.join(queue_dir, f)
            with open(path) as fh:
                c = fh.read()
            # Skip parked tasks — not actionable
            if re.search(r'^status:\s*parked', c, re.MULTILINE):
                continue
            m = re.search(r'^priority:\s*\"?([^\"\n]+)\"?', c, re.MULTILINE)
            p = m.group(1).strip() if m else ''
            tasks.append(f'{f[:-3]}:{p}')
print(','.join(sorted(tasks)))
" "$BRAIN" 2>/dev/null || true)

    if [[ "$NF_FINGERPRINT" != "$CURRENT_FP" ]]; then
      NEXT_FOCUS_STALE=true
    fi

    # Check age (>24h = stale regardless)
    if [[ -n "$NF_GENERATED" ]]; then
      NF_AGE_HOURS=$(python3 -c "
from datetime import datetime, timezone
import sys
try:
    gen = datetime.fromisoformat(sys.argv[1])
    if gen.tzinfo is None:
        gen = gen.replace(tzinfo=timezone.utc)
    age = (datetime.now(timezone.utc) - gen).total_seconds() / 3600
    print(f'{age:.0f}')
except:
    print('0')
" "$NF_GENERATED" 2>/dev/null || echo "0")
      [[ "${NF_AGE_HOURS:-0}" -gt 24 ]] && NEXT_FOCUS_STALE=true
    fi

    # Extract readiness for the top recommended task
    NF_READINESS=$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    recs = d.get('recommendations', [])
    if not recs or 'readiness' not in recs[0] or 'tasks' not in recs[0]:
        print('')
        sys.exit()
    top_task = recs[0]['tasks'][0]
    r = recs[0]['readiness'].get(top_task, {})
    if r.get('executable'):
        print('ready')
    else:
        reason = r.get('block_reason', 'unknown')
        print(f'blocked:{reason}')
except:
    print('')
" "$NEXT_FOCUS_FILE" 2>/dev/null || true)

    # Build section
    if [[ "$NEXT_FOCUS_STALE" == "true" ]]; then
      NEXT_FOCUS_SECTION="- **Prepared Focus:** ~~${NF_SUMMARY}~~ — **stale** (queue changed or >24h). Run \`brain-next-focus --persist\` to refresh."
    else
      NF_TASKS_LINE=""
      [[ -n "$NF_TOP_TASKS" ]] && NF_TASKS_LINE=" Tasks: ${NF_TOP_TASKS}."
      NF_READY_TAG=""
      if [[ "$NF_READINESS" == "ready" ]]; then
        NF_READY_TAG=" **Ready ✓**"
      elif [[ "$NF_READINESS" == blocked:* ]]; then
        NF_BLOCK_REASON="${NF_READINESS#blocked:}"
        NF_READY_TAG=" **Blocked:** ${NF_BLOCK_REASON}"
      fi
      NEXT_FOCUS_SECTION="- **Prepared Focus:** ${NF_SUMMARY} [${NF_FOCUS_TYPE}].${NF_TASKS_LINE}${NF_READY_TAG} _(generated ${NF_GENERATED}Z)_"
    fi
  fi
fi

# ── Collect active incidents (ADR-0004 Phase 0d) ─────────────────
_INC_DIR="$BRAIN/brain/ops/incidents"
INC_SECTION=""
if [[ -d "$_INC_DIR" ]]; then
  INC_SECTION=$(python3 -c "
import json, os, sys
inc_dir = sys.argv[1]
active_phases = {'detected', 'diagnosed'}
lines = []
for fname in sorted(os.listdir(inc_dir)):
    if not fname.endswith('.jsonl'):
        continue
    fpath = os.path.join(inc_dir, fname)
    records = []
    with open(fpath) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                records.append(json.loads(line))
            except json.JSONDecodeError:
                pass
    if not records:
        continue
    last = records[-1]
    first = records[0]
    if last.get('phase', '') not in active_phases:
        continue
    inc_id = fname.replace('.jsonl', '')
    subject = first.get('subject', '')
    detail = first.get('detail', '')[:120]
    confidence = first.get('confidence', '')
    phase = last.get('phase', '')
    lines.append(f'- **{subject}** ({phase}, {confidence}) — {detail}. Incident: \`{inc_id}\`')
if lines:
    print('## Active Incidents')
    print('')
    for l in lines:
        print(l)
    print('')
" "$_INC_DIR" 2>/dev/null || echo "")
fi

# ── Collect diagnostic briefs ──────────────────────────────────────
DIAG_DIR="$_DIAGNOSTICS_DIR"
DIAG_SECTION=""
DIAG_UNRESOLVED=""
DIAG_RESOLVED_COUNT=0
if [[ -d "$DIAG_DIR" ]]; then
  for dfile in "$DIAG_DIR"/*.md; do
    [[ -f "$dfile" ]] || continue
    dname=$(basename "$dfile")
    # Parse frontmatter fields
    d_subject=$(fm_get "$dfile" "subject")
    d_confidence=$(fm_get "$dfile" "confidence")
    d_action=$(fm_get "$dfile" "recommended_action")
    d_resolved=$(fm_get "$dfile" "resolved")
    d_event=$(fm_get "$dfile" "event")
    [[ -z "$d_subject" ]] && continue
    if [[ "$d_resolved" == "true" ]]; then
      DIAG_RESOLVED_COUNT=$((DIAG_RESOLVED_COUNT + 1))
    else
      DIAG_UNRESOLVED="${DIAG_UNRESOLVED}\n- ⚠ **${d_subject}** (${d_event}, ${d_confidence}) — ${d_action}. Brief: \`${dname}\`"
    fi
  done
  # Only show diagnostics section if there are unresolved items.
  # Resolved briefs are silent — archive them when ready.
  if [[ -n "$DIAG_UNRESOLVED" ]]; then
    DIAG_SECTION="## Diagnostics (pre-analyzed)\n${DIAG_UNRESOLVED}\n"
    if [[ $DIAG_RESOLVED_COUNT -gt 0 ]]; then
      DIAG_SECTION="${DIAG_SECTION}\n_${DIAG_RESOLVED_COUNT} resolved diagnostic(s) pending archival in \`work/inbox/diagnostics/\`._\n"
    fi
  fi
fi

