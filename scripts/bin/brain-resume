VERDICT_PATTERNS=""
if [[ -f "$PATTERNS_FILE" ]]; then
  VERDICT_PATTERNS=$(python3 -c "
import json
try:
    patterns = json.load(open('$PATTERNS_FILE')).get('patterns', [])
    vp = [p for p in patterns if p.get('match_surface') == 'verdict_issues']
    for p in vp:
        print(p['signature'] + '|' + p['summary'] + '|' + p['brief'])
except:
