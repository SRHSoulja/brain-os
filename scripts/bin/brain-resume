# ── Generate derived/system-state.md (ADR-0004 Phase 0f cutover) ──
# This is now the canonical system-state writer. The old manual sync path
# has been retired. system-state.md is generated from source data on every
# brain-resume run.
_DERIVED_SSTATE="$BRAIN/brain/ops/derived/system-state.md"
_DERIVED_TMP=$(mktemp "$BRAIN/brain/ops/derived/.system-state.md.XXXXXX")
python3 - "$BRAIN" "$OPS_QUEUED_COUNT" "$OPS_ACTIVE_COUNT" "$OPS_COMPLETED_COUNT" \
  "$VERDICT_STATUS" "$VERDICT_ISSUE_COUNT" "$HEALTH_SUMMARY" "$NOW_DISPLAY" "$_DERIVED_TMP" \
  "$(echo -e "$DOWN_SERVICES")" "${DRIFT_SCORE:-}" "${DRIFT_VERDICT:-}" "${SPOTCHECK_SCORE:-}" <<'PYEOF'
import json, os, sys, re
from datetime import datetime, timezone

brain = sys.argv[1]
q, a, c = sys.argv[2], sys.argv[3], sys.argv[4]
verdict_status = sys.argv[5] or "unknown"
verdict_issues = sys.argv[6] or "0"
health_summary = sys.argv[7] or "unknown"
generated_at = sys.argv[8]
tmp_path = sys.argv[9]
down_services_raw = sys.argv[10] if len(sys.argv) > 10 else ""
drift_score = sys.argv[11] if len(sys.argv) > 11 else ""
drift_verdict = sys.argv[12] if len(sys.argv) > 12 else ""
spotcheck_score = sys.argv[13] if len(sys.argv) > 13 else ""

out = []

# ── Header ──
out.append("---")
out.append(f'generated_at: "{datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")}"')
out.append('type: "derived"')
out.append('generator: "brain-resume"')
out.append("---")
out.append("")
out.append("# System State")
out.append("")
out.append("> **Generated** by brain-resume. Do not hand-edit — changes will be overwritten.")
out.append(f"> Last generated: {generated_at}")
out.append("")

# ── Mission (from active-context.md) ──
ac_path = os.path.join(brain, "brain/index/active-context.md")
mission = ""
focus_lines = []
if os.path.exists(ac_path):
    with open(ac_path) as f:
        content = f.read()
    m = re.search(r'## North Star\s*\n\s*\n(.+?)(?:\n\n|\n##)', content, re.DOTALL)
    if m:
        mission = m.group(1).strip()
    m = re.search(r'## Current Focus Areas\s*\n((?:- .+\n?)+)', content)
    if m:
        focus_lines = [l.strip() for l in m.group(1).strip().split('\n') if l.strip().startswith('- ')]

out.append("## Mission & Focus")
out.append("")
out.append(mission if mission else "_Could not read from active-context.md_")
out.append("")
out.append("_Current focus: see `brain/index/active-context.compact.md` or session-resume.md._")
out.append("")

# ── Operator notes ──
notes_path = os.path.join(brain, "brain/ops/operator-notes.jsonl")
service_notes = {}
agent_notes = []
issue_notes = []
if os.path.exists(notes_path):
    superseded = set()
    entries = []
    with open(notes_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass
    for e in entries:
        sup = e.get("supersedes")
        if sup:
            superseded.add(sup)
    now = datetime.now(timezone.utc)
    for e in entries:
        ts = e.get("ts", "")
        if ts in superseded:
            continue
        ttl = e.get("ttl_hours")
        if ttl is not None:
            try:
                note_time = datetime.fromisoformat(ts.replace("Z", "+00:00"))
                if (now - note_time).total_seconds() > ttl * 3600:
                    continue
            except:
                pass
        ntype = e.get("type", "")
        if ntype == "service-note":
            service_notes[e.get("subject", "")] = e.get("note", "")
        elif ntype == "agent-status":
            agent_notes.append(e)
        elif ntype == "issue":
            issue_notes.append(e)

# ── Service Health (live status + operator notes) ──
# Parse down services from brain-resume's DOWN_SERVICES variable
down_subjects = set()
if down_services_raw.strip():
    for line in down_services_raw.strip().split('\n'):
        m = re.search(r'\*\*(.+?)\*\*', line)
        if m:
            down_subjects.add(m.group(1).lower().strip())

# Known service list with display names
known_services = []

out.append("## Current Status")
out.append("")
out.append("### Service Health")
out.append("")
out.append(f"Status classes: `online` | `degraded` | `down-unexpected` | `inactive-until-stream` | `inactive-on-demand` | `decommissioned`")
out.append("")
out.append("| Service | Status | Notes |")
out.append("|---------|--------|-------|")

status_classes = ["down-unexpected", "degraded", "inactive-until-stream", "inactive-on-demand", "decommissioned"]

for display_name, note_key in known_services:
    note = service_notes.get(note_key, "")
    note_lower = note.lower()
    # Operator-note explicit status: if the note starts with a recognized
    # status class, that status is authoritative (overrides live probe).
    explicit_status = ""
    for sc in status_classes:
        if note_lower.startswith(sc):
            explicit_status = sc
            break
    # Determine status: explicit operator-note > keyword scan > live probe
    name_lower = display_name.lower()
    is_down = False
    for d in down_subjects:
        if name_lower in d or d in name_lower or note_key in d or d in note_key:
            is_down = True
            break
    if explicit_status:
        status = explicit_status
    elif "inactive-until-stream" in note_lower:
        status = "inactive-until-stream"
    elif "inactive-on-demand" in note_lower:
        status = "inactive-on-demand"
    elif is_down:
        status = "down-unexpected"
    else:
        status = "online"
    out.append(f"| {display_name} | {status} | {note} |")
out.append("")

# ── Brain Health ──
out.append("### Brain Health")
out.append("")
out.append("| Metric | Value | Notes |")
out.append("|--------|-------|-------|")

# Spotcheck
if spotcheck_score:
    out.append(f"| Spotcheck | {spotcheck_score} | Claude Haiku 4.5 |")

# Drift
if drift_score:
    out.append(f"| Drift | {drift_score}% {drift_verdict} | Baseline: 3 runs |")

# Export sizes
exports_dir = os.path.join(brain, "work/exports")
core_size = live_size = 0
try:
    core_path = os.path.join(exports_dir, "brain-knowledge-core.json")
    live_path = os.path.join(exports_dir, "brain-knowledge-live.json")
    if os.path.exists(core_path):
        core_size = os.path.getsize(core_path)
    if os.path.exists(live_path):
        live_size = os.path.getsize(live_path)
    if core_size or live_size:
        # Count indexed files from search index
        search_path = os.path.join(exports_dir, "brain-knowledge-search.json")
        indexed = 0
        if os.path.exists(search_path):
            try:
                sd = json.load(open(search_path))
                indexed = len(sd.get("entries", sd.get("documents", [])))
            except:
                pass
        core_kb = f"{core_size // 1024}KB" if core_size else "?"
        live_kb = f"{live_size // 1024}KB" if live_size else "?"
        notes = f"{indexed} files indexed" if indexed else ""
        out.append(f"| Export | core {core_kb}, live {live_kb} | {notes} |")
except:
    pass

# P1/P2
pq_path = os.path.join(brain, "work/logs/priority-queue.md")
p1 = p2 = 0
if os.path.exists(pq_path):
    with open(pq_path) as f:
        pq = f.read()
    b1 = re.search(r'## P1.*?(?=## |$)', pq, re.DOTALL)
    b2 = re.search(r'## P2.*?(?=## |$)', pq, re.DOTALL)
    if b1:
        p1 = len([l for l in b1.group().split('\n') if l.strip().startswith('- ') and 'None' not in l])
    if b2:
        p2 = len([l for l in b2.group().split('\n') if l.strip().startswith('- ') and 'None' not in l])
pq_label = f"{p1} P1, {p2} P2" if p1 + p2 > 0 else "none"
out.append(f"| P1/P2 items | {pq_label} | Priority queue {'clear' if p1+p2==0 else 'has items'} |")
out.append("")

# ── Active Agents ──
out.append("## Active Agents")
out.append("")
out.append("| Agent | Role | Status |")
out.append("|-------|------|--------|")
out.append("| Claude Code | Primary builder, system operator | Active — this session |")
for an in agent_notes:
    out.append(f"| {an.get('subject', '').title()} | {an.get('note', '')} | Available |")
out.append("")

# ── Task Queue ──
out.append("## Task Queue")
out.append("")
out.append("| Location | Count | Notes |")
out.append("|----------|-------|-------|")
ql = f"{q} queued" if int(q) > 0 else "No tasks queued"
al = f"{a} in progress" if int(a) > 0 else "No tasks in progress"
cl = f"{c} completed" if int(c) > 0 else "No tasks completed"
out.append(f"| `brain/ops/tasks/queue/` | {q} | {ql} |")
out.append(f"| `brain/ops/tasks/active/` | {a} | {al} |")
out.append(f"| `brain/ops/tasks/completed/` | {c} | {cl} |")
out.append("")

# ── Open Issues (from operator-notes) ──
if issue_notes:
    out.append("## Open Issues")
    out.append("")
    for iss in issue_notes:
        out.append(f"- {iss.get('note', '')}")
    out.append("")
    out.append("See `work/open-questions.md` for the full list.")
    out.append("")

# ── Recently Changed (events.jsonl + task file summaries) ──
events_path = os.path.join(brain, "brain/ops/events.jsonl")
completions = []
if os.path.exists(events_path):
    with open(events_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
                if ev.get("op") == "TASK_COMPLETE":
                    completions.append(ev)
            except json.JSONDecodeError:
                pass

# Build task_id → summary lookup from task markdown files
task_summaries = {}
for subdir in ("completed", "completed/archive/2026-03"):
    task_dir = os.path.join(brain, "brain/ops/tasks", subdir)
    if not os.path.isdir(task_dir):
        continue
    for fname in os.listdir(task_dir):
        if not fname.startswith("TASK-") or not fname.endswith(".md"):
            continue
        tid = fname.replace(".md", "")
        try:
            with open(os.path.join(task_dir, fname)) as f:
                tc = f.read()
            m = re.search(r'^# (.+)$', tc, re.MULTILINE)
            if m:
                task_summaries[tid] = m.group(1).strip()
        except:
            pass

if completions:
    recent = completions[-5:]
    out.append("## Recently Changed")
    out.append("")
    out.append("| Date | What |")
    out.append("|------|------|")
    for ev in reversed(recent):
        ts = ev.get("ts", "")[:10]
        eid = ev.get("entity_id", "")
        summary = task_summaries.get(eid, eid)
        out.append(f"| {ts} | {eid}: {summary} |")
    out.append("")

# ── Latest Session (from most recent devlog — title + shipped items) ──
devlog_dir = os.path.join(brain, "work/logs/devlog")
if os.path.isdir(devlog_dir):
    devlogs = sorted([f for f in os.listdir(devlog_dir) if f.endswith(".md") and f != "README.md"])
    if devlogs:
        latest = devlogs[-1]
        with open(os.path.join(devlog_dir, latest)) as f:
            dl = f.read()
        title_m = re.search(r'^title:\s*"?(.+?)"?\s*$', dl, re.MULTILINE)
        title = title_m.group(1) if title_m else latest.replace('.md', '')
        out.append(f"## Latest Session")
        out.append("")
        out.append(f"**{title}** ({latest[:10]})")
        out.append("")
        # Extract summary from the first content section (What shipped / Shipped / What changed)
        shipped_m = re.search(r'## (?:What shipped|Shipped|What changed)\s*\n(.*?)(?:\n## |\Z)', dl, re.DOTALL)
        if shipped_m:
            shipped_lines = []
            for line in shipped_m.group(1).strip().split('\n'):
                # Capture ### headings and top-level bullets
                if line.startswith('### '):
                    shipped_lines.append(f"- {line[4:].strip()}")
                elif line.startswith('- ') and not line.startswith('  '):
                    shipped_lines.append(line)
            if shipped_lines:
                for sl in shipped_lines[:8]:
                    out.append(sl)
                out.append("")
            else:
                # No bullets or headings — grab first non-empty paragraph
                first_para = shipped_m.group(1).strip().split('\n\n')[0].strip()
                if first_para and not first_para.startswith('|'):
                    out.append(first_para[:200])
                    out.append("")

# "Where This File Fits" table removed for token efficiency.
# See CLAUDE.md Key Paths for file role reference.

with open(tmp_path, "w") as f:
    f.write("\n".join(out) + "\n")
