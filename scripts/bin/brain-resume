#!/bin/bash
# brain-resume — generate session continuity briefing for Claude Code
# Usage: brain-resume [--new-session] [--quiet] [--close-refresh]
#
# Reads brain state and writes brain/index/session-resume.md
# Run before starting a Claude Code session in ~/brain (or $BRAIN_DIR)
#
# --new-session  Reset the session timer. Use only for true session starts
#                (SessionStart hook). Mid-session callers (brain-task-complete,
#                brain-meditate) omit this flag to preserve session timing.
# --close-refresh  Regenerate only post-close consumer artifacts
#                  (session-resume + derived/system-state). Skips startup-facing
#                  derivatives (active-context.compact, digest-preamble,
#                  session-start-contract, session-brief).

set -euo pipefail

NEW_SESSION=false
CLOSE_REFRESH=false
for arg in "$@"; do
  case "$arg" in
    --new-session) NEW_SESSION=true ;;
    --close-refresh) CLOSE_REFRESH=true ;;
  esac
done

BRAIN="${BRAIN_DIR:-$HOME/brain}"
# Resolve through symlinks so ~/bin wrappers can source libs reliably.
_SELF_SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$_SELF_SOURCE" ]]; do
  _SELF_DIR="$(cd -P "$(dirname "$_SELF_SOURCE")" && pwd)"
  _SELF_SOURCE="$(readlink "$_SELF_SOURCE")"
  [[ "$_SELF_SOURCE" != /* ]] && _SELF_SOURCE="$_SELF_DIR/$_SELF_SOURCE"
done
_SELF_DIR="$(cd -P "$(dirname "$_SELF_SOURCE")" && pwd)"
. "$_SELF_DIR/../lib/brain-paths.sh"
TOOLS="${_TOOLS:-${BRAIN_DIR:-$HOME/brain}/scripts}"
. "$_SELF_DIR/../lib/frontmatter.sh"
RESUME="$_SESSION_RESUME"
NOW_ISO=$(date -u +%Y-%m-%dT%H:%M:%SZ)
NOW_DISPLAY=$(date +"%Y-%m-%d at %I:%M %p %Z")

# Record session start for brain-timer — only on true new sessions.
# Mid-session callers (task-complete, meditate) must not reset this.
SESSION_START_FILE="${BRAIN_SESSION_START_FILE:-$HOME/.brain-session-start}"
if [[ "$SESSION_START_FILE" == "$HOME/.brain-session-start" ]]; then
  # Some runtimes expose HOME as read-only; fall back to a repo-local marker.
  if { [[ ! -f "$SESSION_START_FILE" ]] && [[ ! -w "$HOME" ]]; } || \
     { [[ -f "$SESSION_START_FILE" ]] && [[ ! -w "$SESSION_START_FILE" ]]; }; then
    SESSION_START_FILE="$BRAIN/brain/ops/.brain-session-start"
  fi
fi
mkdir -p "$(dirname "$SESSION_START_FILE")"
if $NEW_SESSION || [[ ! -f "$SESSION_START_FILE" ]]; then
  date +%s > "$SESSION_START_FILE"
fi
export BRAIN_SESSION_START_FILE="$SESSION_START_FILE"

# Reset chain depth (escalation policy — new session = fresh chain)
# Skip reset when called from brain-task-complete (preserves mid-chain count)
if [[ -z "${BRAIN_SKIP_CHAIN_RESET:-}" ]]; then
  echo "0" > "$BRAIN/brain/ops/.chain-depth"
fi

# ── Verify brain exists ────────────────────────────────────────────
if [[ ! -d "$BRAIN" ]]; then
  echo "Error: Brain repo not found at $BRAIN"
  exit 1
fi

# Public repo isolation: VE/dual-seat sync paths are disabled.
VE_SYNC_STATUS="disabled"

# ── 000. Latest session handoff ───────────────────────────────────
HANDOFF_DIR="$BRAIN/work/session-handoffs"
LATEST_HANDOFF=""
HANDOFF_CONTENT=""
if [[ -d "$HANDOFF_DIR" ]]; then
  latest_hf=$(ls -t "$HANDOFF_DIR"/*-handoff.md 2>/dev/null | head -1 || true)
  if [[ -n "$latest_hf" && -f "$latest_hf" ]]; then
    LATEST_HANDOFF=$(basename "$latest_hf")
    # Extract sections (skip frontmatter)
    HANDOFF_CONTENT=$(sed '1,/^---$/{ /^---$/!d; /^---$/d; }' "$latest_hf" | sed '1,/^---$/d')
  fi
fi

# ── 001. Latest spotcheck score ──────────────────────────────────
SPOTCHECK_DIR="$BRAIN/work/logs/clip-health"
SPOTCHECK_SCORE=""
SPOTCHECK_FAILS=0
SPOTCHECK_DATE=""
if [[ -d "$SPOTCHECK_DIR" ]]; then
  latest_sc=$(ls -t "$SPOTCHECK_DIR"/*-spotcheck.md 2>/dev/null | head -1 || true)
  if [[ -n "$latest_sc" && -f "$latest_sc" ]]; then
    SPOTCHECK_DATE=$(grep '^generated:' "$latest_sc" | sed 's/.*"\(.*\)"/\1/' | head -1)
    SPOTCHECK_SCORE=$(grep '^\*\*Score:' "$latest_sc" | head -1)
    SPOTCHECK_FAILS=$(grep -c '^| \*\*FAIL\*\*' "$latest_sc" 2>/dev/null || echo "0")
  fi
fi

# ── 002. Latest ingest digest ────────────────────────────────────
INGEST_DIR="$BRAIN/work/inbox/clip-learnings"
INGEST_COUNT=0
LATEST_INGEST=""
if [[ -d "$INGEST_DIR" ]]; then
  INGEST_COUNT=$(ls "$INGEST_DIR"/*-digest.md 2>/dev/null | wc -l | tr -d ' ' || echo "0")
  latest_ig=$(ls -t "$INGEST_DIR"/*-digest.md 2>/dev/null | head -1 || true)
  if [[ -n "$latest_ig" ]]; then
    LATEST_INGEST=$(basename "$latest_ig")
  fi
fi

# ── 002b. Latest deploy timestamp ──────────────────────────────────
DEPLOY_AGE_LABEL=""
EXPORT_LOG="$BRAIN/work/logs/brain-export.log"
if [[ -f "$EXPORT_LOG" ]]; then
  deploy_line=$(grep '\[DEPLOY\].*deploy=success' "$EXPORT_LOG" | tail -1 || true)
  if [[ -n "$deploy_line" ]]; then
    # Try deploy_ts= field first, fall back to timestamp after [DEPLOY]
    deploy_ts=$(echo "$deploy_line" | sed -n 's/.*deploy_ts=\([^ ]*\).*/\1/p')
    [[ -z "$deploy_ts" ]] && deploy_ts=$(echo "$deploy_line" | sed 's/\[DEPLOY\] \([^ ]*\).*/\1/')
    if [[ -n "$deploy_ts" ]]; then
      deploy_epoch=$(date -d "$deploy_ts" +%s 2>/dev/null || echo "")
      if [[ -n "$deploy_epoch" ]]; then
        now_epoch=$(date +%s)
        age_hours=$(( (now_epoch - deploy_epoch) / 3600 ))
        if [[ $age_hours -lt 24 ]]; then
          DEPLOY_AGE_LABEL="Last deploy: ${age_hours}h ago"
        else
          age_days=$(( age_hours / 24 ))
          DEPLOY_AGE_LABEL="⚠ Last deploy: ${age_days}d ago — Clip may be serving stale knowledge"
        fi
      fi
    fi
  fi
fi
[[ -z "$DEPLOY_AGE_LABEL" ]] && DEPLOY_AGE_LABEL="⚠ No deploy timestamp found"

# ── 002c. Social signal ingest (runs inline, ~2s) ─────────────────
SIGNAL_DIR="$BRAIN/work/inbox/social-signals"
SIGNAL_SUMMARY=""
SIGNAL_VERDICT=""
"$TOOLS/bin/brain-ingest-signals" > /dev/null 2>&1 || true
if [[ -d "$SIGNAL_DIR" ]]; then
  latest_sig=$(ls -t "$SIGNAL_DIR"/*-blog-traffic.md 2>/dev/null | head -1 || true)
  if [[ -n "$latest_sig" ]]; then
    sig_date=$(basename "$latest_sig" | sed 's/-blog-traffic.md//')
    sig_visits=$(grep 'Blog post views' "$latest_sig" 2>/dev/null | grep -oP '\d+' | tail -1 || echo "0")
    sig_guide=$(grep 'Guide clicks |' "$latest_sig" 2>/dev/null | grep -oP '\d+' | tail -1 || echo "0")
    sig_product=$(grep 'Product clicks |' "$latest_sig" 2>/dev/null | grep -oP '\d+' | tail -1 || echo "0")
    sig_x=$(grep 't.co.*referrals' "$latest_sig" 2>/dev/null | grep -oP '\d+' | tail -1 || echo "0")
    SIGNAL_VERDICT=$(grep '^\*\*Verdict:' "$latest_sig" 2>/dev/null | sed 's/\*\*Verdict: //' | sed 's/\*\*//' || echo "")
    # Extract first interpretation bullet if verdict is action or watch
    SIGNAL_REASON=$(grep '^\- ' "$latest_sig" 2>/dev/null | head -1 | sed 's/^- //' || echo "")
    # Build funnel suffix (only show non-zero product metrics)
    _funnel=""
    [[ "$sig_product" -gt 0 ]] && _funnel=", ${sig_product} product clicks"
    case "$SIGNAL_VERDICT" in
      action)
        SIGNAL_SUMMARY="Blog: ${sig_visits} views, ${sig_guide} guide clicks${_funnel}, ${sig_x} from X -- ACTION: ${SIGNAL_REASON} ($sig_date)"
        ;;
      watch)
        SIGNAL_SUMMARY="Blog: ${sig_visits} views, ${sig_guide} guide clicks${_funnel}, ${sig_x} from X -- watch ($sig_date)"
        ;;
      *)
        SIGNAL_SUMMARY="Blog: ${sig_visits} views, ${sig_guide} guide clicks${_funnel}, ${sig_x} from X ($sig_date)"
        ;;
    esac
  fi
fi

# ── 00. Latest checkpoint from today ─────────────────────────────
CHECKPOINT_DIR="$BRAIN/work/inbox/checkpoints"
LATEST_CHECKPOINT=""
CHECKPOINT_NOTE=""
if [[ -d "$CHECKPOINT_DIR" ]]; then
  today=$(date +%Y-%m-%d)
  latest=$(ls -t "$CHECKPOINT_DIR"/${today}*.md 2>/dev/null | head -1 || true)
  if [[ -n "$latest" && -f "$latest" ]]; then
    LATEST_CHECKPOINT=$(basename "$latest")
    CHECKPOINT_NOTE=$(grep '^\*\*Reason:\*\*' "$latest" 2>/dev/null | sed 's/\*\*Reason:\*\* //' || true)
    # Extract key state: repos with changes and ahead counts
    CHECKPOINT_CHANGES=$(grep -c '^\- \*\*Changed:\*\* [^n]' "$latest" 2>/dev/null || echo "0")
    CHECKPOINT_AHEAD=$(grep -c 'ahead of remote' "$latest" 2>/dev/null || echo "0")
  fi
fi

# ── 0. Priority queue (P1/P2 items) ──────────────────────────────
P1_ITEMS=$(pq_items P1)
P2_ITEMS=$(pq_items P2)
P1_COUNT=0
P2_COUNT=0
[[ -n "$P1_ITEMS" ]] && P1_COUNT=$(echo "$P1_ITEMS" | grep -c '^\- ' || true)
[[ -n "$P2_ITEMS" ]] && P2_COUNT=$(echo "$P2_ITEMS" | grep -c '^\- ' || true)

# ── 0a. Queued messages (HIGHEST PRIORITY) ─────────────────────────
QUEUED_MESSAGES=""
QUEUED_COUNT=0
QUEUE_FILE="$BRAIN/work/inbox/messages/queue.md"
if [[ -f "$QUEUE_FILE" ]]; then
  QUEUED_MESSAGES=$(grep '^\- ' "$QUEUE_FILE" 2>/dev/null || true)
  if [[ -n "$QUEUED_MESSAGES" ]]; then
    QUEUED_COUNT=$(echo "$QUEUED_MESSAGES" | wc -l | tr -d ' ')
  fi
fi

CORRECTIONS=""
CORRECTIONS_COUNT=0
if [[ -n "${BRAIN_CORRECTIONS_HOST:-}" ]]; then
  CORRECTIONS=$(ssh -4 "$BRAIN_CORRECTIONS_HOST" "python3 -c \"
import json
with open('${BRAIN_CORRECTIONS_PATH:-/brain/corrections.json}') as f:
    data = json.load(f)
new_ones = [c for c in data if c.get('status') == 'new']
for c in new_ones[-10:]:
    print('- [' + c.get('timestamp','')[:16] + '] said: ' + c.get('clip_said','')[:80] + ' ... correction: ' + c.get('correction','')[:120])
\"" 2>/dev/null)
  if [[ -n "$CORRECTIONS" ]]; then
    CORRECTIONS_COUNT=$(echo "$CORRECTIONS" | wc -l | tr -d ' ')
  fi
fi

# ── 0c. Pending reminders ─────────────────────────────────────────
REMINDERS_DIR="$BRAIN/work/inbox/reminders"
FIRED_REMINDERS=""
PENDING_REMINDERS=""
FIRED_COUNT=0
PENDING_REMINDER_COUNT=0
if [[ -d "$REMINDERS_DIR" ]]; then
  now_ts=$(date +%s)
  if compgen -G "$REMINDERS_DIR/*.md" > /dev/null 2>&1; then
  for f in "$REMINDERS_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    fire_ts=$(grep '^fire_at:' "$f" | sed 's/fire_at: *//' | head -1)
    msg=$(grep '^message:' "$f" | sed 's/message: *//' | head -1)
    set_at=$(grep '^set_at:' "$f" | sed 's/set_at: *//' | head -1)
    [[ -z "$fire_ts" || -z "$msg" ]] && continue
    if (( now_ts >= fire_ts )); then
      FIRED_REMINDERS="${FIRED_REMINDERS}\n- **FIRED:** $msg _(set $set_at)_"
      FIRED_COUNT=$((FIRED_COUNT + 1))
    else
      fire_display=$(grep '^fire_display:' "$f" | sed 's/fire_display: *//' | head -1)
      PENDING_REMINDERS="${PENDING_REMINDERS}\n- **Pending:** $msg _(fires $fire_display)_"
      PENDING_REMINDER_COUNT=$((PENDING_REMINDER_COUNT + 1))
    fi
  done
  fi
fi

# ── 0d. Recent activity log (last 5 entries) ──────────────────────
ACTIVITY_LOG="$BRAIN/nodes/coaching/docs/activity-log.md"
RECENT_ACTIVITY=""
if [[ -f "$ACTIVITY_LOG" ]]; then
  # Last 3 entries, notes truncated to 60 chars
  RECENT_ACTIVITY=$(grep '^|' "$ACTIVITY_LOG" | grep -v '^| Date' | grep -v '^|---' | tail -3 | awk -F'|' '{
    date=$2; type=$3; notes=$4;
    gsub(/^ +| +$/, "", notes);
    if (length(notes) > 60) notes = substr(notes, 1, 57) "...";
    printf "| %s | %s | %s |\n", date, type, notes
  }')
fi

# ── 1. Last session activity (git log) ─────────────────────────────
COMMITS=$(cd "$BRAIN" && git log --oneline -5 2>/dev/null || echo "(no git history)")

# ── 2. Current focus areas ─────────────────────────────────────────
# Prefer compact file for console output; fall back to full file
FOCUS=""
_AC_COMPACT="$BRAIN/brain/index/active-context.compact.md"
if [[ -f "$_AC_COMPACT" ]]; then
  FOCUS=$(sed -n '/^## Current Focus$/,/^## /{/^## Current Focus$/d;/^## /d;p;}' \
    "$_AC_COMPACT" | sed '/^$/d')
fi
if [[ -z "$FOCUS" && -f "$BRAIN/brain/index/active-context.md" ]]; then
  FOCUS=$(sed -n '/^## Current Focus Areas/,/^## /{/^## Current Focus/d;/^## /d;p;}' \
    "$BRAIN/brain/index/active-context.md" | sed '/^$/d')
fi
[[ -z "$FOCUS" ]] && FOCUS="_Could not read active-context.md._"

# ── 3. System health ──────────────────────────────────────────────
HEALTH_SUMMARY="_System status not available._"
DOWN_SERVICES=""
if [[ -f "$BRAIN/work/logs/system-status.md" ]]; then
  SUMMARY_LINE=$(grep -E '^[0-9]+/[0-9]+ .* services' "$BRAIN/work/logs/system-status.md" 2>/dev/null || true)
  if [[ -n "$SUMMARY_LINE" ]]; then
    HEALTH_SUMMARY="$SUMMARY_LINE"
  fi
  # Only surface down-unexpected alerts, not inactive services
  DOWN_SERVICES=$(sed -n '/^## Alerts/,/^## /{/^- \*\*/p;}' "$BRAIN/work/logs/system-status.md" 2>/dev/null | grep -v "inactive-until-stream" | grep -v "inactive-on-demand" || true)

  # Cross-reference operator-notes: suppress services whose operator
  # classification is inactive-on-demand or decommissioned (live probe
  # sees "down" but the operator decided it's intentionally off or retired).
  if [[ -n "$DOWN_SERVICES" && -f "$BRAIN/brain/ops/operator-notes.jsonl" ]]; then
    _inactive_subjects=$(python3 -c "
import json, sys
suppress_prefixes = ('inactive-on-demand', 'decommissioned')
for line in open(sys.argv[1]):
    line = line.strip()
    if not line: continue
    try:
        e = json.loads(line)
    except: continue
    if e.get('type') == 'service-note' and e.get('note','').lower().startswith(suppress_prefixes):
        print(e.get('subject',''))
" "$BRAIN/brain/ops/operator-notes.jsonl" 2>/dev/null || true)
    if [[ -n "$_inactive_subjects" ]]; then
      while IFS= read -r _isub; do
        [[ -z "$_isub" ]] && continue
        # Map subject keys to display names for grep filtering
        _iname="$_isub"
        case "$_isub" in
          strikes-engine) _iname="Strikes Engine" ;;
          strikes-observe) _iname="Strikes Observe" ;;
          brain-export-webhook) _iname="Brain Export Hook" ;;
        esac
        DOWN_SERVICES=$(echo "$DOWN_SERVICES" | grep -iv "$_iname" || true)
      done <<< "$_inactive_subjects"
    fi
  fi
fi

# ── 3b. Cron daemon health ────────────────────────────────────────
CRON_HEALTHY=true
if ! pgrep -x cron > /dev/null 2>&1; then
  CRON_HEALTHY=false
  DOWN_SERVICES="${DOWN_SERVICES}\n- **WSL cron daemon** — NOT RUNNING. All scheduled Brain jobs are dead. Run: \`sudo service cron start\`"
fi

# ── 3b-ii. SO-005: Check expected WSL PM2 services ───────────────
# Laptop WSL PM2 has no expected always-on services.
# Remote-seat services: brain-agent, brain-monitor, brain-dashboard, reverse-tunnel

# ── 3b-iii. Surface recent health sweep incidents ─────────────────
SWEEP_LOG="$BRAIN/work/logs/health-sweep.log"
SWEEP_INCIDENTS=""
if [[ -f "$SWEEP_LOG" ]]; then
  # Show non-HEALTHY entries from the last 24 hours
  _cutoff=$(date -u -d '24 hours ago' +%Y-%m-%dT%H:%M:%S 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%S)
  SWEEP_INCIDENTS=$(awk -v cutoff="$_cutoff" '$1 >= cutoff && $3 != "HEALTHY" { print }' "$SWEEP_LOG" 2>/dev/null || true)
  if [[ -n "$SWEEP_INCIDENTS" ]]; then
    _incident_count=$(echo "$SWEEP_INCIDENTS" | wc -l | tr -d ' ')
    # Surface as a separate section, not as a down service (avoids SO-004 false match)
    SWEEP_SUMMARY="$_incident_count health-sweep incident(s) in last 24h — check \`work/logs/health-sweep.log\`"
  fi
fi

# ── 3b-iv. Overnight summary ─────────────────────────────────────
# Parse health-sweep.log for the last 24h to build a concise overnight report.
VE_SUMMARY=""
if [[ -f "$SWEEP_LOG" ]]; then
  VE_SUMMARY=$(python3 - "$SWEEP_LOG" "$BRAIN" <<'PYEOF'
import sys, os, glob
from datetime import datetime, timezone, timedelta

sweep_log = sys.argv[1]
brain = sys.argv[2]
cutoff = datetime.now(timezone.utc) - timedelta(hours=24)
cutoff_str = cutoff.strftime("%Y-%m-%dT%H:%M:%S")

# Parse sweep log
total_sweeps = 0
healthy = 0
degraded = 0
unhealthy = 0
remedies = []
failures = []

try:
    with open(sweep_log) as f:
        for line in f:
            if not line.startswith("2") or "HEALTH_SWEEP" not in line:
                continue
            parts = line.strip().split()
            if len(parts) < 3:
                continue
            ts = parts[0]
            if ts < cutoff_str:
                continue
            total_sweeps += 1
            verdict = parts[2]
            if verdict == "HEALTHY":
                healthy += 1
            elif verdict == "DEGRADED":
                degraded += 1
            elif verdict == "UNHEALTHY":
                unhealthy += 1
            # Extract remedies
            if "remedies=" in line:
                r = line.split("remedies=")[1].split(" ")[0].strip()
                if r:
                    remedies.append(r)
            # Extract failures (excluding stale verdict which is noise)
            if "failures=" in line:
                f_text = line.split("failures=")[1].split("warnings=")[0].strip()
                if f_text and "State verdict: STALE" not in f_text:
                    failures.append(f_text)
except:
    pass

# Count suggestion files (unarchived)
suggestions_dir = os.path.join(brain, "work/inbox/ollama-suggestions")
suggestion_count = 0
if os.path.isdir(suggestions_dir):
    suggestion_count = len(glob.glob(os.path.join(suggestions_dir, "*.md")))

# Rate file for SO-006 restarts
rate_file = os.path.join(brain, "work/logs/.service-restart-timestamps")
restarts_24h = 0
if os.path.isfile(rate_file):
    cutoff_epoch = cutoff.timestamp()
    try:
        with open(rate_file) as f:
            for line in f:
                parts = line.strip().split()
                if parts and float(parts[0]) > cutoff_epoch:
                    restarts_24h += 1
    except:
        pass

# Build summary
if total_sweeps == 0:
    print("_No health-sweep data in last 24h._")
    sys.exit(0)

parts = []
parts.append(f"{total_sweeps} sweeps")
if unhealthy:
    parts.append(f"**{unhealthy} UNHEALTHY**")
if degraded:
    parts.append(f"{degraded} degraded")
if healthy:
    parts.append(f"{healthy} healthy")

line1 = "Health: " + ", ".join(parts)

extras = []
if remedies:
    extras.append(f"Remedies applied: {', '.join(remedies)}")
if restarts_24h:
    extras.append(f"SO-006 restarts: {restarts_24h}")
if failures:
    # Deduplicate and show unique failure types
    unique_failures = list(dict.fromkeys(failures))[:3]
    for uf in unique_failures:
        extras.append(f"Failure: {uf.rstrip('; ')}")
if suggestion_count:
    extras.append(f"Agent suggestions: {suggestion_count} pending")

print(line1)
for e in extras:
    print(e)
PYEOF
  )
fi

# ── 3c. Match down services against known diagnostic patterns ─────
PATTERNS_FILE="$_DIAGNOSTICS_PATTERNS"
if [[ -n "$DOWN_SERVICES" && -f "$PATTERNS_FILE" ]]; then
  DOWN_SERVICES=$(echo -e "$DOWN_SERVICES" | python3 -c "
import json, sys

try:
    patterns = json.load(open('$PATTERNS_FILE')).get('patterns', [])
except:
    patterns = []

ds_patterns = [p for p in patterns if p.get('match_surface') == 'down_services']
output_lines = []
for line in sys.stdin:
    line = line.rstrip('\n')
    output_lines.append(line)
    for p in ds_patterns:
        if p.get('match_type') == 'contains' and p['signature'] in line:
            output_lines.append('  → **Known pattern** — ' + p['summary'] + ' (brief: \`' + p['brief'] + '\`)')
            break
print('\n'.join(output_lines))
" 2>/dev/null || echo -e "$DOWN_SERVICES")
fi

# ── 3e. SO-004: Create diagnostic briefs for unmatched service failures ──
# If a down service has no matching pattern, write a low-confidence brief.
# Stop condition: max 3 new briefs per resume run to prevent cascade-spam.
if [[ -n "$DOWN_SERVICES" && -f "$PATTERNS_FILE" ]]; then
  python3 -c "
import json, os, sys, re
from datetime import datetime, timezone

brain = sys.argv[1]
patterns_file = sys.argv[2]
down_text = sys.argv[3]
diag_dir = sys.argv[4]

try:
    patterns = json.load(open(patterns_file)).get('patterns', [])
except:
    patterns = []

sigs = [p['signature'] for p in patterns if p.get('match_surface') == 'down_services' and p.get('signature')]
now = datetime.now(timezone.utc)
created = 0

for line in down_text.split('\n'):
    if not line.strip().startswith('- **'):
        continue
    # Check if any pattern matches this line
    matched = any(sig in line for sig in sigs)
    if matched:
        continue

    # Extract service name from '- **Service Name** — detail'
    m = re.match(r'- \*\*(.+?)\*\*', line)
    if not m:
        continue
    svc_name = m.group(1)

    # Skip if we already have a brief for this subject
    slug = svc_name.lower().replace(' ', '-').replace(':', '')
    brief_path = os.path.join(diag_dir, f'{slug}-auto.md')
    if os.path.exists(brief_path):
        continue

    # Stop condition: max 3 per run
    if created >= 3:
        print(f'[SO-004] WARNING: >3 unmatched failures — stopping brief creation (escalate)', file=sys.stderr)
        break

    # Extract detail
    detail = line.split('—', 1)[1].strip() if '—' in line else 'unknown'

    # Write brief
    os.makedirs(diag_dir, exist_ok=True)
    with open(brief_path, 'w') as f:
        f.write(f'''---
type: \"diagnostic\"
event: \"service-down\"
subject: \"{svc_name}\"
pattern: \"\"
confidence: \"low\"
recommended_action: \"Investigate — no known pattern. Check logs and service health.\"
resolved: false
resolved_on: \"\"
validated: false
validated_on: \"\"
validation_outcome: \"\"
---

# {svc_name} — Unmatched Service Failure

## What happened

{svc_name} detected as down-unexpected. Detail: {detail}

## Diagnosis

No known pattern matched this failure. This brief was auto-created by Standing Order SO-004. Investigation required.

## Recommended action

Check service logs, PM2 status, and health endpoints. Once resolved, update this brief and consider adding a pattern to patterns.json if the issue is likely to recur.
''')
    created += 1
    print(f'  SO-004: Created brief for {svc_name} ({brief_path})')
" "$BRAIN" "$PATTERNS_FILE" "$(echo -e "$DOWN_SERVICES")" "$_DIAGNOSTICS_DIR" 2>&1 || true
fi

# ── 3d. Match verdict issues against known diagnostic patterns ─────
