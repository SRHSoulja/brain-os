#!/usr/bin/env bun
/**
 * brain-secret — local encrypted secret manager
 * Usage: brain-secret <command> [args]
 */

import { init, addSecret, getSecret, deleteSecret, listSecrets, exportVault, isInitialized, getConfig } from "../lib/vault.js";
import { spawnSync } from "child_process";
import { join } from "path";
import { homedir } from "os";

const SCRIPT_DIR = new URL(".", import.meta.url).pathname;
const SERVER_SCRIPT = join(SCRIPT_DIR, "brain-secret-server");

const HELP = `
brain-secret — encrypted local secret manager

Commands:
  init                        Generate encryption key and initialize vault
  add <KEY> <value>           Add or update a secret
    --label "My API Key"      Human-readable label (optional)
    --cat   <category>        Category tag (default: general)
  get <KEY>                   Print secret value to stdout
  list                        List all secret names (no values)
  delete <KEY>                Remove a secret
  export                      Dump all secrets as JSON (values included)
  serve [--port N]            Start the web dashboard (default port: 7734)
  status                      Show vault status

Examples:
  brain-secret init
  brain-secret add OPENAI_API_KEY sk-abc123 --label "OpenAI" --cat ai
  brain-secret get OPENAI_API_KEY
  brain-secret serve --port 7734
`;

const args = process.argv.slice(2);
const cmd = args[0];

function parseFlags(args) {
  const flags = {};
  for (let i = 0; i < args.length; i++) {
    if (args[i].startsWith("--")) {
      flags[args[i].slice(2)] = args[i + 1] ?? true;
      i++;
    }
  }
  return flags;
}

function requireInit() {
  if (!isInitialized()) {
    console.error("Vault not initialized. Run: brain-secret init");
    process.exit(1);
  }
}

switch (cmd) {
  case "init": {
    try {
      const result = init();
      if (result.alreadyExists) {
        console.log("Vault already initialized.");
      } else {
        console.log("Vault initialized.");
        console.log(`  Key file:  ~/.config/brain-vault/key.age`);
        console.log(`  Vault:     ~/.brain-vault/vault.age`);
        console.log(`  Public key: ${result.pubkey}`);
        console.log(`\nBackup your key file to a safe location (USB, password manager).`);
      }
    } catch (e) {
      console.error("Init failed:", e.message);
      process.exit(1);
    }
    break;
  }

  case "add": {
    requireInit();
    const key = args[1];
    const value = args[2];
    if (!key || !value) {
      console.error("Usage: brain-secret add <KEY> <value> [--label ...] [--cat ...]");
      process.exit(1);
    }
    const flags = parseFlags(args.slice(3));
    try {
      addSecret(key, value, { label: flags.label, category: flags.cat });
      console.log(`Stored: ${key}`);
    } catch (e) {
      console.error("Failed:", e.message);
      process.exit(1);
    }
    break;
  }

  case "get": {
    requireInit();
    const key = args[1];
    if (!key) { console.error("Usage: brain-secret get <KEY>"); process.exit(1); }
    try {
      const s = getSecret(key);
      process.stdout.write(s.value);
    } catch (e) {
      console.error(e.message);
      process.exit(1);
    }
    break;
  }

  case "list": {
    requireInit();
    const secrets = listSecrets();
    if (secrets.length === 0) { console.log("No secrets stored."); break; }
    const maxKey = Math.max(...secrets.map(s => s.key.length), 3);
    const maxLabel = Math.max(...secrets.map(s => s.label.length), 5);
    console.log(`${"KEY".padEnd(maxKey)}  ${"LABEL".padEnd(maxLabel)}  CATEGORY`);
    console.log(`${"─".repeat(maxKey)}  ${"─".repeat(maxLabel)}  ────────`);
    for (const s of secrets) {
      console.log(`${s.key.padEnd(maxKey)}  ${s.label.padEnd(maxLabel)}  ${s.category}`);
    }
    break;
  }

  case "delete": {
    requireInit();
    const key = args[1];
    if (!key) { console.error("Usage: brain-secret delete <KEY>"); process.exit(1); }
    try {
      deleteSecret(key);
      console.log(`Deleted: ${key}`);
    } catch (e) {
      console.error(e.message);
      process.exit(1);
    }
    break;
  }

  case "export": {
    requireInit();
    try {
      const data = exportVault();
      console.log(JSON.stringify(data, null, 2));
    } catch (e) {
      console.error("Export failed:", e.message);
      process.exit(1);
    }
    break;
  }

  case "serve": {
    requireInit();
    const flags = parseFlags(args.slice(1));
    const port = flags.port || getConfig().port || 7734;
    const result = spawnSync("bun", ["run", SERVER_SCRIPT, "--port", String(port)], {
      stdio: "inherit",
      env: { ...process.env },
    });
    process.exit(result.status ?? 0);
    break;
  }

  case "status": {
    const initialized = isInitialized();
    console.log(`Vault initialized: ${initialized ? "yes" : "no"}`);
    if (initialized) {
      const secrets = listSecrets();
      const cfg = getConfig();
      console.log(`Secrets stored:   ${secrets.length}`);
      console.log(`Dashboard port:   ${cfg.port || 7734}`);
      console.log(`Vault path:       ~/.brain-vault/vault.age`);
      console.log(`Key path:         ~/.config/brain-vault/key.age`);
    }
    break;
  }

  default: {
    console.log(HELP);
    break;
  }
}
