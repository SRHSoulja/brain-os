#!/bin/bash
# brain-session — Auto-restarting agent wrapper
# Usage: brain-session [--agent <claude|gemini|codex>] [--auto-restart]
#
# Launches the specified AI agent. When a session ends (exit or meditate),
# optionally relaunches with a fresh session when --auto-restart is set.

# Resolve canonical repo root via this script path so operator launchers are
# robust even when shell env exports an incorrect BRAIN_DIR.
_SELF_SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$_SELF_SOURCE" ]]; do
  _SELF_DIR="$(cd -P "$(dirname "$_SELF_SOURCE")" && pwd)"
  _SELF_SOURCE="$(readlink "$_SELF_SOURCE")"
  [[ "$_SELF_SOURCE" != /* ]] && _SELF_SOURCE="$_SELF_DIR/$_SELF_SOURCE"
done
_SELF_DIR="$(cd -P "$(dirname "$_SELF_SOURCE")" && pwd)"
BRAIN_DIR="$(cd "$_SELF_DIR/../.." && pwd)"
export BRAIN_DIR

AGENT="claude"
AUTO_RESTART="${BRAIN_SESSION_AUTO_RESTART:-0}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent) AGENT="$2"; shift 2 ;;
    --auto-restart) AUTO_RESTART=1; shift ;;
    *) break ;;
  esac
done

echo "=== Brain Session Manager: $AGENT ==="
if [[ "$AUTO_RESTART" == "1" ]]; then
  echo "Auto-restart: enabled"
else
  echo "Auto-restart: disabled (single-launch mode)"
fi
echo ""

while true; do
  # Clean up stale signal files from prior sessions
  rm -f "$BRAIN_DIR/brain/ops/.session-restart"

  # Launcher bootstrap (fail-closed): do not enter an agent shell unless
  # seat bootstrap succeeded for this launch path.
  BOOTSTRAP_OK=1
  if [[ "$AGENT" == "codex" ]]; then
    "$HOME/bin/brain-codex-enter" --mode interactive >/dev/null
    BOOTSTRAP_OK=$?
  else
    "$HOME/bin/brain-agent-bootstrap" --agent "$AGENT" --mode interactive >/dev/null
    BOOTSTRAP_OK=$?
  fi
  if [[ "$BOOTSTRAP_OK" -ne 0 ]]; then
    echo "[brain-session] bootstrap failed for agent=$AGENT (exit=$BOOTSTRAP_OK)."
    echo "[brain-session] launcher is fail-closed; agent session not started."
    exit "$BOOTSTRAP_OK"
  fi

  export BRAIN_SESSION_PID=$$
  export BRAIN_BOOTSTRAP_DONE=1
  
  if [[ "$AGENT" == "claude" ]]; then
    # Claude uses native binary via PATH
    command claude --channels plugin:discord@claude-plugins-official
  elif [[ "$AGENT" == "gemini" ]]; then
    # Gemini uses its own wrapper in ~/bin
    "$HOME/bin/gemini"
  elif [[ "$AGENT" == "codex" ]]; then
    # Codex uses its own wrapper in ~/bin
    "$HOME/bin/codex"
  else
    # Generic command fallback
    "$AGENT"
  fi
  
  EXIT_CODE=$?

  # Check if explicit restart signal (created by brain-meditate-restart)
  if [[ -f "$BRAIN_DIR/brain/ops/.session-restart" ]]; then
    rm "$BRAIN_DIR/brain/ops/.session-restart"
    echo "Restart signal detected. Relaunching..."
    sleep 1
    continue
  fi

  # Normal exit
  echo ""
  echo "Session ended (exit code: $EXIT_CODE)"
  if [[ "$AUTO_RESTART" != "1" ]]; then
    echo "Auto-restart disabled. Exiting."
    break
  fi
  # Non-interactive sessions must never loop.
  if [[ ! -t 0 ]]; then
    echo "No interactive TTY detected. Exiting without restart."
    break
  fi
  read -t 5 -p "Restart? [Y/n] (auto-restart in 5s): " choice
  case "${choice:-y}" in
    [nN]*) echo "Goodbye."; break ;;
    *) echo "Restarting..."; echo ""; sleep 1 ;;
  esac
done
