#!/bin/bash
# brain-session — Auto-restarting agent wrapper
# Usage: brain-session [--agent <claude|gemini|codex>]
#
# Launches the specified AI agent. When a session ends (exit or meditate),
# automatically relaunches with a fresh session. Ctrl+C twice to fully stop.

BRAIN_DIR="${BRAIN_DIR:-$HOME/brain}"
AGENT="claude"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent) AGENT="$2"; shift 2 ;;
    *) break ;;
  esac
done

echo "=== Brain Session Manager: $AGENT ==="
echo "Sessions auto-restart on exit. Ctrl+C twice to stop."
echo ""

while true; do
  # Clean up stale signal files from prior sessions
  rm -f "$BRAIN_DIR/brain/ops/.session-ve-handoff"
  rm -f "$BRAIN_DIR/brain/ops/.session-restart"

  # Unified bootstrap for all agents
  "$HOME/bin/brain-agent-bootstrap" --agent "$AGENT" --mode interactive >/dev/null 2>&1 || true

  export BRAIN_SESSION_PID=$$
  
  if [[ "$AGENT" == "claude" ]]; then
    # Claude uses native binary via PATH
    command claude --channels plugin:discord@claude-plugins-official
  elif [[ "$AGENT" == "gemini" ]]; then
    # Gemini uses its own wrapper in ~/bin
    "$HOME/bin/gemini"
  elif [[ "$AGENT" == "codex" ]]; then
    # Codex uses its own wrapper in ~/bin
    "$HOME/bin/codex"
  else
    # Generic command fallback
    "$AGENT"
  fi
  
  EXIT_CODE=$?

  # 1. Check if VE handoff — exit cleanly, no restart
  if [[ -f "$BRAIN_DIR/brain/ops/.session-ve-handoff" ]]; then
    rm "$BRAIN_DIR/brain/ops/.session-ve-handoff"
    echo ""
    echo "=== Session handed to VE. Laptop going quiet. ==="
    echo ""
    break
  fi

  # 2. Check if explicit restart signal (created by brain-meditate-restart)
  if [[ -f "$BRAIN_DIR/brain/ops/.session-restart" ]]; then
    rm "$BRAIN_DIR/brain/ops/.session-restart"
    echo "Restart signal detected. Relaunching..."
    sleep 1
    continue
  fi

  # 3. Check if heartbeat says yielded — VE seat monitor will pick up
  HB_FILE="$BRAIN_DIR/brain/ops/.laptop-heartbeat.json"
  if [[ -f "$HB_FILE" ]]; then
    HB_STATUS=$(python3 -c "import json; print(json.load(open('$HB_FILE')).get('status',''))" 2>/dev/null || echo "")
    if [[ "$HB_STATUS" == "yielded" ]]; then
      echo ""
      echo "=== Heartbeat is 'yielded'. VE will take over. Laptop going quiet. ==="
      echo ""
      break
    fi
  fi

  # Normal exit — ask before restarting
  echo ""
  echo "Session ended (exit code: $EXIT_CODE)"
  read -t 5 -p "Restart? [Y/n] (auto-restart in 5s): " choice
  case "${choice:-y}" in
    [nN]*) echo "Goodbye."; break ;;
    *) echo "Restarting..."; echo ""; sleep 1 ;;
  esac
done
