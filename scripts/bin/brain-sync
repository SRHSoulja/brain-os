#!/bin/bash
# brain-sync — Pull repos, commit agent outputs, auto-deploy on new commits
#
# Runs on remote seat cron (every 15 min).
# This is the live sync script that replaced the ADR-0004 dry-run skeleton.
#
# Flow:
#   1. Clean stale git locks
#   2. Commit local agent outputs (suggestions, health logs, status files)
#   3. Pull brain repo from remote (stash all dirty state first)
#   4. Push any local commits (agent outputs) to remote — only if pull succeeded
#   5. Pull tools repo from remote
#   6. If brain repo advanced from remote, run brain-export --deploy
#   7. Post-deploy: trigger spotcheck + brain-assess for verification
#
# Write surfaces:
#   - work/inbox/ollama-suggestions/ (git add)
#   - work/logs/health-sweep.log (git add)
#   - work/logs/system-status.md (git add)
#   - work/logs/system-status.json (git add)
#   - ~/logs/brain-sync.log (append-only log)
#
# Safety:
#   - Agent outputs are additive (new files or appended logs) -- safe to auto-commit
#   - Pull uses --rebase to keep history linear
#   - Never force-pushes
#   - Deploy only fires when remote brought new commits (not on local-only changes)

set -uo pipefail

LOG="$HOME/logs/brain-sync.log"
TOOLS="$HOME/gmgn-brain/scripts"
BRAIN="$HOME/gmgn-brain"

mkdir -p "$(dirname "$LOG")"
cd "$BRAIN"

_log() { echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) $*" >> "$LOG"; }

# Step 0a: Skip destructive git ops if VE Claude session is active
# Committing agent outputs and pushing is safe, but pull/stash could poison an active session
VE_LOCK="$BRAIN/brain/ops/.ve-session.lock"
VE_SESSION_ACTIVE=false
if [[ -f "$VE_LOCK" ]]; then
  VE_PID=$(cat "$VE_LOCK" 2>/dev/null || echo "")
  if [[ -n "$VE_PID" ]] && kill -0 "$VE_PID" 2>/dev/null; then
    VE_SESSION_ACTIVE=true
    _log "VE session active (PID $VE_PID) -- will commit+push only, skip pull"
  fi
fi

# Step 0b: Clean stale index.lock (from crashed git processes)
LOCK="$BRAIN/.git/index.lock"
if [[ -f "$LOCK" ]]; then
  lock_age=$(( $(date +%s) - $(stat -c %Y "$LOCK") ))
  if [[ $lock_age -gt 300 ]]; then
    rm -f "$LOCK"
    _log "removed stale index.lock (${lock_age}s old)"
  else
    _log "SKIP: index.lock exists (${lock_age}s old, may be active)"
    exit 0
  fi
fi

# Step 1: Commit any local agent outputs before pulling
AGENT_PATHS=(
  "work/inbox/ollama-suggestions/"
  "work/logs/health-sweep.log"
  "work/logs/system-status.md"
  "work/logs/system-status.json"
  "work/logs/session-summary-latest.json"
)
CHANGED=false
for p in "${AGENT_PATHS[@]}"; do
  if [[ -e "$p" ]] && ! git diff --quiet -- "$p" 2>/dev/null; then
    git add "$p" 2>/dev/null
    CHANGED=true
  fi
done
# Also add any new untracked suggestion files
for f in work/inbox/ollama-suggestions/*.md; do
  [[ -f "$f" ]] && git ls-files --error-unmatch "$f" 2>/dev/null || { git add "$f" 2>/dev/null; CHANGED=true; }
done

if $CHANGED; then
  git commit -m "brain-sync auto-commit: agent outputs" >> "$LOG" 2>&1
  _log "committed local agent outputs"
fi

# Step 2: Pull from remote (SKIP if VE session active -- prevents poisoning working state)
BEFORE=$(git rev-parse HEAD 2>/dev/null)
AFTER="$BEFORE"
PULL_OK=false

if $VE_SESSION_ACTIVE; then
  _log "SKIP pull: VE session active. Commit+push only."
  PULL_OK=true  # don't block push of agent outputs
else
  # Stash ALL dirty state (working tree + index + untracked agent files)
  # before pulling. The previous stash-only-working-tree approach failed
  # when health-sweep wrote between commit and pull, leaving both staged
  # and unstaged changes.
  STASHED=false
  if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
    git stash push -q --include-untracked -m "brain-sync: pre-pull stash" >> "$LOG" 2>&1 && STASHED=true
  fi

  if git pull --rebase origin main >> "$LOG" 2>&1; then
    PULL_OK=true
  else
    _log "WARN: git pull failed"
  fi

  if $STASHED; then
    # Discard local changes to derived state files before popping stash.
    # These are regenerable and the pulled version (from laptop/session) is authoritative.
    # Without this, stash pop overwrites freshly-pulled derived state with stale local copies.
    git checkout -- brain/ops/derived/ 2>/dev/null
    git stash pop -q >> "$LOG" 2>&1 || _log "WARN: stash pop conflict -- manual resolution needed"
  fi

  AFTER=$(git rev-parse HEAD 2>/dev/null)
fi

# Step 3: Push if we have local commits AND pull succeeded
LOCAL=$(git rev-list origin/main..HEAD --count 2>/dev/null)
if [[ "$LOCAL" -gt 0 ]]; then
  if $PULL_OK; then
    if git push origin main >> "$LOG" 2>&1; then
      _log "pushed $LOCAL local commit(s)"
    else
      _log "WARN: push failed ($LOCAL local commits pending)"
    fi
  else
    _log "SKIP push: pull failed, $LOCAL local commit(s) waiting"
  fi
fi

# Step 4: Pull all project repos
cd "$TOOLS" && git pull --ff-only origin master >> "$LOG" 2>&1

PROJECT_REPOS=(
  "$HOME/2026Projects/clip-the-intern"
  "$HOME/2026Projects/xbot"
  "$HOME/2026Projects/strikes"
  "$HOME/2026Projects/arcbot"
  "$HOME/2026Projects/slapz-server"
  "$HOME/2026Projects/timeweaver"
  "$HOME/2026Projects/claude-code-hud"
  "$HOME/2026Projects/brain-agent-hackathon"
  "$HOME/codex-lab"
)
for repo in "${PROJECT_REPOS[@]}"; do
  [[ -d "$repo/.git" ]] || continue
  repo_name=$(basename "$repo")
  cd "$repo"
  # Determine default branch
  branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  [[ -z "$branch" ]] && branch="main"
  if git pull --ff-only origin "$branch" >> "$LOG" 2>&1; then
    :
  else
    _log "WARN: $repo_name pull failed (may need manual resolution)"
  fi
done

# Step 5: Auto-deploy if brain repo advanced from remote
cd "$BRAIN"
if [[ "$BEFORE" != "$AFTER" ]]; then
  _log "new commits detected, deploying..."
  PATH="$TOOLS/bin:$PATH" brain-export --deploy >> "$LOG" 2>&1
  DEPLOY_EXIT=$?

  if [[ $DEPLOY_EXIT -eq 0 ]]; then
    _log "deploy complete"

    # Step 6: Post-deploy verification (non-blocking)
    # Spotcheck verifies Clip's answer quality with fresh knowledge.
    # brain-assess refreshes signal assessment + checks expectations.
    SPOTCHECK="$TOOLS/bin/brain-spotcheck"
    ASSESS="$TOOLS/bin/brain-assess"

    if [[ -x "$SPOTCHECK" ]]; then
      _log "post-deploy: triggering spotcheck"
      nohup "$SPOTCHECK" >> "$BRAIN/work/logs/brain-spotcheck.log" 2>&1 &
    else
      _log "post-deploy: brain-spotcheck not found, skipping"
    fi

    if [[ -x "$ASSESS" ]]; then
      "$ASSESS" > /dev/null 2>&1 && _log "post-deploy: assessment refreshed" || _log "post-deploy: brain-assess failed"
    fi
  else
    _log "WARN: deploy failed (exit $DEPLOY_EXIT)"
  fi
else
  _log "sync complete (no new commits)"
fi
