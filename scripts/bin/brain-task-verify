#!/usr/bin/env bash
# brain-task-verify — Automated post-task audit verification via summoned verifier
# Usage: brain-task-verify <TASK-ID> [--by <agent>]

set -euo pipefail

BRAIN="${BRAIN_DIR:-$HOME/brain}"
TOOLS="${BRAIN_DIR:-$HOME/brain}/scripts"
. "$TOOLS/lib/brain-paths.sh"
_require_local
OPS_DIR="$_OPS_TASKS_DIR"

TASK_ID=""
AGENT="${BRAIN_AGENT:-claude-code}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --by) AGENT="$2"; shift 2 ;;
    *)    TASK_ID="$1"; shift ;;
  esac
done

if [[ -z "$TASK_ID" ]]; then
  echo "Error: TASK-ID required" >&2
  exit 1
fi

COMPLETED_FILE="$OPS_DIR/completed/${TASK_ID}.md"
if [[ ! -f "$COMPLETED_FILE" ]]; then
  echo "Error: Task $TASK_ID not found in completed/" >&2
  exit 1
fi

# 1. Read coordination signal and dependencies from frontmatter
FM_DATA=$(python3 -c "
import sys, yaml, json
try:
    with open('$COMPLETED_FILE', 'r') as f:
        content = f.read()
        if '---' in content:
            fm = yaml.safe_load(content.split('---')[1])
            data = {
                'coordination': fm.get('audit_coordination', 'independent'),
                'depends_on': fm.get('depends_on', [])
            }
            if isinstance(data['depends_on'], str):
                data['depends_on'] = [data['depends_on']]
            print(json.dumps(data))
except:
    print(json.dumps({'coordination': 'independent', 'depends_on': []}))
" 2>/dev/null || echo "{\"coordination\": \"independent\", \"depends_on\": []}")

COORDINATION=$(echo "$FM_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin).get('coordination','independent'))")
DEPENDS_ON=$(echo "$FM_DATA" | python3 -c "import json,sys; print(' '.join(json.load(sys.stdin).get('depends_on',[])))")

# 2. Check dependency status if coordination is not independent
if [[ "$COORDINATION" != "independent" ]]; then
  ALL_DEPS_DONE=true
  for dep in $DEPENDS_ON; do
    if [[ ! -f "$OPS_DIR/completed/${dep}.md" ]]; then
      ALL_DEPS_DONE=false
      break
    fi
  done

  if [[ "$ALL_DEPS_DONE" == "false" ]]; then
    if [[ "$COORDINATION" == "wait" ]]; then
      echo "[verify] $TASK_ID set to 'wait' — skipping automated audit until dependencies ($DEPENDS_ON) are cleared."
      exit 0
    elif [[ "$COORDINATION" == "combined" ]]; then
      echo "[verify] $TASK_ID requires 'combined' audit — waiting for dependencies ($DEPENDS_ON)."
      exit 0
    fi
  fi
fi

# 3. Handle combined audit sequencing
TARGET_IDS="$TASK_ID"
if [[ "$COORDINATION" == "combined" ]]; then
  echo "[verify] Performing COMBINED audit for $TASK_ID and its dependencies ($DEPENDS_ON)..."
  TARGET_IDS="$TASK_ID $DEPENDS_ON"
fi

# 3b. Gemini attribution signature check
if [[ "$AGENT" == "gemini" ]]; then
  _DOC_PATTERNS="brain/wiki/.*\.md$|brain/governance/.*\.md$|docs/.*\.md$|brain/MANUAL\.md$|README\.md$|CLAUDE\.md$|AGENTS\.md$|GEMINI\.md$"
  _changed_docs=$(
    { git -C "$BRAIN" diff HEAD --name-only 2>/dev/null
      git -C "$BRAIN" ls-files --others --exclude-standard 2>/dev/null
    } | grep -E "$_DOC_PATTERNS" | sort -u || true
  )
  _missing_sig=()
  while IFS= read -r _doc; do
    [[ -z "$_doc" ]] && continue
    _full="$BRAIN/$_doc"
    [[ -f "$_full" ]] || continue
    if ! grep -q "sovereign-agent-sig: gemini" "$_full"; then
      _missing_sig+=("$_doc")
    fi
  done <<< "$_changed_docs"
  if [[ ${#_missing_sig[@]} -gt 0 ]]; then
    echo "GEMINI_SIGNATURE_MISSING: add <!-- sovereign-agent-sig: gemini --> to all modified documentation files"
    for _f in "${_missing_sig[@]}"; do
      echo "  missing: $_f"
    done
    exit 1
  fi
fi

# 3c. Attestation gate (agent-agnostic, fail-closed) ────────────────
ATT_JSON=$(python3 - "$COMPLETED_FILE" <<'PYEOF'
import re, json, sys
path = sys.argv[1]
txt = open(path).read()
m = re.search(r'##\s+Attestation\b.*?```json\s*(\{.*?\})\s*```', txt, flags=re.DOTALL|re.IGNORECASE)
if not m:
    print(""); sys.exit(0)
try:
    print(json.dumps(json.loads(m.group(1))))
except Exception:
    print(""); sys.exit(0)
PYEOF
)
if [[ -z "$ATT_JSON" ]]; then
  echo "VERIFY_ATTESTATION_MISSING: no well-formed Attestation block in $TASK_ID. Run brain-task-attest before verify." >&2
  exit 1
fi

ATT_BY=$(echo "$ATT_JSON"   | python3 -c "import json,sys; print(json.load(sys.stdin).get('attested_by',''))")
ATT_FILES=$(echo "$ATT_JSON" | python3 -c "import json,sys; print('\n'.join(json.load(sys.stdin).get('files_changed',[])))")
ATT_CHECKS=$(echo "$ATT_JSON" | python3 -c "import json,sys; print('\t'.join(json.load(sys.stdin).get('checks_declared',[])))")

# 3c.i — Claimant/attestor identity match
FM_OWNER=$(python3 -c "
import sys, yaml
txt=open('$COMPLETED_FILE').read()
print(yaml.safe_load(txt.split('---')[1]).get('owner','') if '---' in txt else '')
" 2>/dev/null || echo "")
if [[ -n "$FM_OWNER" && "$ATT_BY" != "$FM_OWNER" ]]; then
  echo "VERIFY_IDENTITY_MISMATCH: attested_by=$ATT_BY owner=$FM_OWNER" >&2
  exit 1
fi

# 3c.ii — Re-run every declared check. All must exit 0.
if [[ -n "$ATT_CHECKS" ]]; then
  _fail=0
  while IFS= read -r _cmd; do
    [[ -z "$_cmd" ]] && continue
    if ! ( cd "$BRAIN" && bash -c "$_cmd" ) >/dev/null 2>&1; then
      echo "VERIFY_CHECK_FAILED: $_cmd" >&2
      _fail=1
    fi
  done < <(printf '%s\n' "$ATT_CHECKS" | tr '\t' '\n')
  if [[ "$_fail" -ne 0 ]]; then
    echo "Audit gate BLOCKED for $TASK_ID: one or more declared checks failed." >&2
    exit 1
  fi
fi

# 3c.iii — git diff must be subset of attested files_changed.
if [[ -n "$ATT_FILES" ]]; then
  _diff_base=$(git -C "$BRAIN" log -n 1 --format=%H -- "$COMPLETED_FILE" 2>/dev/null || echo "")
  if [[ -n "$_diff_base" ]]; then
    # Exclude task-system bookkeeping files authored by brain-task-complete
    # (the task's own .md and .completion.json) — they are system-authored,
    # not agent-authored, and can never appear in Attestation.files_changed.
    _changed=$(git -C "$BRAIN" diff-tree --no-commit-id --name-only -r "$_diff_base" 2>/dev/null \
      | grep -v "^brain/ops/tasks/completed/${TASK_ID}\.md$" \
      | grep -v "^brain/ops/tasks/completed/${TASK_ID}\.completion\.json$" \
      || true)
    _extra=$(
      comm -23 \
        <(printf '%s\n' "$_changed" | sort -u) \
        <(printf '%s\n' "$ATT_FILES" | sort -u)
    )
    _extra_trim=$(printf '%s\n' "$_extra" | grep -v '^$' || true)
    if [[ -n "$_extra_trim" ]]; then
      echo "VERIFY_FILES_UNATTESTED: files touched in commit but not in Attestation.files_changed:" >&2
      echo "$_extra_trim" | sed 's/^/  /' >&2
      exit 1
    fi
  fi
fi

# 4. Summon verifier via repo-auditor profile
echo "[verify] Summoning verifier for $TARGET_IDS (profile: repo-auditor)..."
QUESTION="Please audit the completion of the following task(s): $TARGET_IDS. 
- Verify that all criteria in each task file were met.
- Confirm structural integrity of any artifacts touched.
- Check if documentation (wiki, manifest) was updated.
- For combined audits: verify the integrated behavior across all related tasks.
- If everything looks correct, respond with 'VERIFIED'. 
- If issues are found, list them clearly."

VERIFICATION_RESULT=$("$BRAIN/scripts/bin/brain-subagent-dispatch" --profile repo-auditor --question "$QUESTION" 2>/dev/null || true)

if echo "$VERIFICATION_RESULT" | grep -qi "VERIFIED"; then
  echo "[verify] Automated audit passed for $TARGET_IDS."
  # Clear the gate(s)
  for tid in $TARGET_IDS; do
    $BRAIN/scripts/bin/brain-task-confirm "$tid" --by "$AGENT" > /dev/null 2>&1 || true
    echo "[verify] Audit gate cleared for $tid."
  done
else
  echo "[verify] Automated audit FAILED or produced findings for $TARGET_IDS."
  echo "--- VERIFIER OUTPUT ---"
  echo "$VERIFICATION_RESULT" | jq -r '.result' 2>/dev/null || echo "$VERIFICATION_RESULT"
  echo "--- END ---"
  echo "Audit gate remains BLOCKED for $TASK_ID. Human review or manual confirm required."
  exit 1
fi
